<aside class="sidebar d-none d-lg-block" id="collection-sidebar-product">
  {%- for block in section.blocks -%}
    {% case block.type %}
      {%- when 'banner' -%}
        {%- render 'sidebar-snippet', type: 'banner', block: block, section: section -%}
  
      {%- when 'products-listing' -%}
        {%- render 'sidebar-snippet', type: 'products-listing', block: block, section: section -%}
  
      {%- when 'service' -%}
        {%- render 'sidebar-snippet', type: 'service', block: block, section: section -%}

    {% endcase %}
  {%- endfor -%}
</aside>