<link rel="stylesheet" href="{{'section-featured-collection.css' | asset_url}}" media="print" onload="this.media='all'">

{%- liquid
  assign border_radius = section.settings.border_radius
  assign bg_image = section.settings.bg_image
  assign style= section.settings.style
  assign position= section.settings.position
  assign image = section.settings.image
  assign link = section.settings.link
  assign limit = section.settings.limit
  assign enable_slider = section.settings.enable_slider
  assign dots  = section.settings.dots
  assign loop  = section.settings.loop
  assign controls = section.settings.controls
  assign controls_position = section.settings.controls_position
  assign autoplay = section.settings.autoplay
  assign collection = collections[section.settings.collection]
  assign sectionID  = '#section-' | append: section.id
  assign items_resp = section.settings.items_resp
  assign controls_id = '#controls-' | append: section.id
  assign items_spacing = section.settings.items_spacing
  assign autoplay_timeout = section.settings.autoplay_timeout
  assign heading_style_block = section.blocks | where: 'type' , 'heading-style' | first
  assign slider_id = '#slider-' | append: section.id

  assign layout = section.settings.layout
  if layout == 'boxed'
    assign layout_class = 'container'
  else
    assign layout_class = 'container-fluid'
  endif

  if border_radius
    assign bg_class = ' .section-wrapper'
  else
    assign bg_class = ''
  endif

  if items_spacing
    if style == 'countdown'
      assign items_spacing_slider = '4px'
    elsif style == 'textbox'
      assign items_spacing_slider = '4px'
    else
      assign items_spacing_slider = '30px'
    endif
  else
    assign items_spacing_slider = '0'
    if style == 'countdown'
      assign items_spacing_row = 'no-padding'
    elsif style == 'textbox'
      assign items_spacing_row = 'no-padding'
    endif
  endif

  if items_spacing == false and enable_slider == false
    assign items_spacing_row = 'no-padding'
  endif
-%}

{%- capture bg_wide -%}{%- render 'bg_responsive' image_desk: bg_image, image_mobi: bg_image -%}{%- endcapture -%}

{%- assign _expire = section.settings.expire -%}

{%- capture section_heading -%}
  {%- render 'snippet-heading', type: 'render-html', config: section.settings -%}
{%- endcapture -%}

{%- assign items_array = items_resp | split: ',' -%}
{%- assign items_desk = items_array[0] | default: 4 -%}
{%- assign items_tab = items_array[2] | default: 3 -%}
{%- assign items_mob = items_array[3] | default: 2 -%}
{%- assign grid_gap = '0px' -%}
{%- if items_spacing -%}
  {%- assign grid_gap = '30px' -%}
  {%- if style == 'countdown' or style == 'textbox' -%}
    {%- assign grid_gap = '4px' -%}
  {%- endif -%}
{%- endif -%}

<style>
  #section-{{section.id}} {
    --grid-gap: {{ grid_gap }};
    --items-per-row-desk: {{ items_desk }};
    --items-per-row-tab: {{ items_tab }};
    --items-per-row-mob: {{ items_mob }};
  }
  #section-{{section.id}} .slider-list {
    display: flex;
    gap: var(--grid-gap);
  }
  #section-{{section.id}} .slider-item {
    flex: 0 0 calc((100% - (var(--grid-gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
    max-width: calc((100% - (var(--grid-gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
  }
  @media (max-width: 991px) {
    #section-{{section.id}} .slider-item {
      flex: 0 0 calc((100% - (var(--grid-gap) * (var(--items-per-row-tab) - 1))) / var(--items-per-row-tab));
      max-width: calc((100% - (var(--grid-gap) * (var(--items-per-row-tab) - 1))) / var(--items-per-row-tab));
    }
  }
  @media (max-width: 767px) {
    #section-{{section.id}} .slider-item {
      flex: 0 0 calc((100% - (var(--grid-gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
      max-width: calc((100% - (var(--grid-gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
    }
  }
  {% unless enable_slider %}
  #section-{{section.id}} .grid-layout {
    flex-wrap: wrap;
  }
  {% endunless %}
</style>

<div class="section-featured-collection {% if border_radius %}border-radius{% endif %} {{bg_wide}}" id="section-{{section.id}}" data-section-id="{{section.id}}"{% if enable_slider %} data-section-type="featured-collection"{% endif %}>
  <div class="{% if layout == 'full' %}container-fluid{% else %}container{% endif %} controls-position-{{controls_position}}">
    <div class="section-wrapper block-type-{{style}} countdown-position-{{position}} {{items_spacing_row}}">

      {%- if section_heading != blank -%}
        {%- capture heading_css -%}
          {%- render 'snippet-heading' type: 'render-css' config: heading_style_block.settings, classID: sectionID -%}
        {%- endcapture -%}
        <div class="section-header">
          {{section_heading}}
        </div>
      {%- endif -%}

      <div class="section-body">
        {%- case style -%}
          {%- when 'image' -%}
            {%- unless image == blank -%}
              <div class="block-image">
                <div class="block-image-inner">
                  <a href="{{ link }}">
                    {%- render 'image-style' image: image, limit: 768 -%}
                  </a>
                </div>
              </div>
            {%- endunless -%}

          {%- when 'countdown' -%}
            {%- if position == '2' -%}
              {%- assign _background = block.settings.bg_color -%}

              {%- unless _expire == blank -%}
                {%- assign _dueDate = _expire | split: '/' -%}
                {%- assign _text_1 = section.settings.text_1 -%}
                {%- assign _text_2 = section.settings.text_2 -%}
                {%- assign _image = section.settings.icon -%}

                <div class="block-countdown">
                  <div class="block-countdown-inner">
                      {%- unless _text_1 == blank -%}<span class="countdown-title">{{ _text_1 }}</span>{%- endunless -%}

                      {%- unless _image == blank -%}
                        <div class="block-image">
                          {%- render 'image-style' image: _image, limit: 768 -%}
                        </div>
                      {%- endunless -%}

                      {%- unless _text_2 == blank -%}<span class="countdown-text">{{ _text_2 }}</span>{%- endunless -%}

                      <div class="product-countdown" data-dueDate-year="{{ _dueDate[2] }}" data-dueDate-month="{{ _dueDate[0] | plus:0 }}" data-dueDate-day="{{ _dueDate[1] | plus:0 }}">
                        <div class="countdown-html countdown_{{ section.id }}"></div>
                      </div>
                  </div>
                </div>
              {%- endunless -%}
            {%- endif -%}

          {%- when 'textbox' -%}
          {%- assign textbox_1 = section.settings.textbox_1 -%}
          {%- assign textbox_2 = section.settings.textbox_2 -%}
          {%- assign button_label = section.settings.button_label -%}
          {%- assign button_link = section.settings.button_link -%}

          <div class="block-textbox">
            <div class="textbox-inner">
              {%- unless textbox_1 == blank -%}<div class="text-1">{{ textbox_1 }}</div>{%- endunless -%}
              {%- unless textbox_2 == blank -%}<div class="text-2">{{ textbox_2 }}</div>{%- endunless -%}
              {%- unless button_label == blank -%}<a href="{{button_link}}" class="btn btn-1">{{ button_label }}</a>{%- endunless -%}
            </div>
          </div>

        {%- else -%}
        {%- endcase -%}

        <div class="block-slider-component">
          {%- if enable_slider -%}
          <native-slider data-autoplay="{{ autoplay }}" data-autoplay-timeout="{{ autoplay_timeout | default: 5000 }}">
            <div class="slider-header-controls">
              {%- if controls -%}
                <button type="button" class="slider-prev-button" aria-label="Previous">
                  {% render 'icon-dir-left' %}
                </button>
                <button type="button" class="slider-next-button" aria-label="Next">
                  {% render 'icon-dir-right' %}
                </button>
              {%- endif -%}
            </div>
            <div class="slider-container">
          {%- endif -%}
              
              <div class="slider-list{% unless enable_slider %} grid-layout{% endunless %}" id="slider-{{section.id}}">
                {%- for product in collection.products limit: limit -%}
                  <div class="slider-item">
                    {%- render 'product-item' product: product, collection: collection-%}
                  </div>
                {%- endfor -%}
              </div>

          {%- if enable_slider -%}
            </div>
            {%- if dots -%}
            <div class="slider-dots"></div>
            {%- endif -%}
          </native-slider>
          {%- endif -%}
        </div>
        </div> 

      </div>

    </div>
  </div>
</div>



{%- capture section_css -%}
  {{-heading_css-}}
  {%- render 'snippet-theme' type: 'section-style', preClassID: sectionID, classID: bg_class, config: section.settings -%}
{%- endcapture -%}
{%- style -%}{{section_css | strip | strip_newlines | remove: '  ' }}{%- endstyle -%}
{%- schema -%}
{
  "name": "Featured Collection",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout Mode",
      "default": "boxed",
      "options": [
        { "value": "boxed", "label": "Boxed" },
        { "value": "full", "label": "Wide" }
      ]
    },
    {
      "type": "text",
      "id": "margin",
      "label": "Section Margin",
      "info": "Order: Top Right Bottom Left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "text",
      "id": "padding",
      "label": "Section Padding",
      "info": "Order: Top Right Bottom Left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "header",
      "content": "Design & Colors"
    },
    {
      "type": "select",
      "id": "style",
      "label": "Section Style",
      "default": "normal",
      "options": [
        { "value": "normal", "label": "Normal Grid" },
        { "value": "image", "label": "Image Banner Beside" },
        { "value": "countdown", "label": "Countdown Banner Beside" },
        { "value": "textbox", "label": "Textbox Beside" }
      ]
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "checkbox",
      "id": "border_radius",
      "label": "Enable Border Radius"
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Target Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Maximum Products to Show",
      "step": 1,
      "min": 1,
      "max": 20,
      "default": 10
    },
    {
      "type": "header",
      "content": "Grid Settings"
    },
    {
      "type": "text",
      "id": "items_resp",
      "label": "Items Per Row (Responsive)",
      "default": "6,5,3,2",
      "info": "Format: Desktop-Large, Desktop, Tablet, Mobile"
    },
    {
      "type": "checkbox",
      "id": "items_spacing",
      "label": "Enable Spacing Between Items",
      "default": true
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "label": "Enable Native Slider",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Infinite Loop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "Show Arrow Controls",
      "default": true
    },
    {
      "type": "select",
      "id": "controls_position",
      "label": "Controls Position",
      "options": [
        { "value": "1", "label": "Inline with Heading" },
        { "value": "2", "label": "Below Heading" }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "dots",
      "label": "Show Slider Pagination Dots",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_timeout",
      "label": "Autoplay Timeout",
      "step": 0.1,
      "min": 2,
      "max": 10,
      "unit": "s",
      "default": 4
    },
    {
      "type": "header",
      "content": "Block Style: Image"
    },
    {
      "type": "paragraph",
      "content": "Settings used only if 'Section Style' is set to 'Image Banner Beside'"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side Image"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Image Link"
    },
    {
      "type": "header",
      "content": "Block Style: Countdown"
    },
    {
      "type": "paragraph",
      "content": "Settings used only if 'Section Style' is set to 'Countdown'"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Countdown Position",
      "options": [
        { "value": "1", "label": "Same Row with Heading" },
        { "value": "2", "label": "Below Heading" }
      ],
      "default": "2"
    },
    {
      "type": "textarea",
      "id": "text_1",
      "label": "Primary Text"
    },
    {
      "type": "textarea",
      "id": "text_2",
      "label": "Subtext"
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Icon Image"
    },
    {
      "type": "text",
      "id": "expire",
      "label": "Expiration Date",
      "info": "Format: mm/dd/yyyy. Example: 12/20/2023"
    },
    {
      "type": "header",
      "content": "Block Style: Textbox"
    },
    {
      "type": "paragraph",
      "content": "Settings used only if 'Section Style' is set to 'Textbox Beside'"
    },
    {
      "type": "textarea",
      "id": "textbox_1",
      "label": "Textbox Header"
    },
    {
      "type": "textarea",
      "id": "textbox_2",
      "label": "Textbox Description"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "heading-style",
      "limit": 1,
      "name": "Heading Custom Styles",
      "settings": [
        {
          "type": "select",
          "id": "section_heading_container_align",
          "label": "Heading Alignment",
          "options": [
            { "value": "auto", "label": "Auto" },
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ]
        },
        {
          "type": "text",
          "id": "section_heading_margin",
          "label": "Heading Margin",
          "info": "Order: Top Right Bottom Left (e.g. 10px 0 10px 0)"
        },
        {
          "type": "color",
          "id": "section_heading_color",
          "label": "Text Color"
        },
        {
          "type": "text",
          "id": "section_heading_font_size",
          "label": "Font Size",
          "info": "e.g., 24px"
        },
        {
          "type": "range",
          "id": "section_heading_font_weight",
          "label": "Font Weight",
          "step": 100,
          "min": 100,
          "max": 900,
          "default": 600
        },
        {
          "type": "text",
          "id": "section_heading_line_height",
          "label": "Line Height",
          "info": "e.g., 32px"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{%- endschema -%}