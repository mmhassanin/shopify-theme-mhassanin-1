<link rel="stylesheet" href="{{'section-featured-blog.css' | asset_url}}" media="print" onload="this.media='all'">

{%- liquid
  assign bg_class = ''
  assign limit = section.settings.limit
  assign enable_slider = section.settings.enable_slider
  assign dots  = section.settings.dots
  assign loop  = section.settings.loop
  assign controls = section.settings.controls
  assign autoplay = section.settings.autoplay
  assign blog = blogs[section.settings.blog]
  assign sectionID  = '#section-' | append: section.id
  assign items_resp = section.settings.items_resp
  assign controls_id = '#controls-' | append: section.id
  assign items_spacing = section.settings.items_spacing
  assign autoplay_timeout = section.settings.autoplay_timeout
  assign heading_style_block = section.blocks | where: 'type' , 'heading-style' | first
  assign slider_id = '#slider-' | append: section.id

  assign layout = section.settings.layout
  if layout == 'boxed'
    assign layout_class = 'container'
  else
    assign layout_class = 'container-fluid'
  endif

  if items_spacing
    assign items_spacing_slider = '30px'
  else
    assign items_spacing_slider = '0'
    assign items_spacing_row = 'no-padding'
  endif
-%}

{%- capture section_heading -%}
  {%- render 'snippet-heading' type:'render-html' config: section.settings -%}
{%- endcapture -%}

{%- capture gridClass -%}{%- render 'set-item-per-row', value: items_resp -%}{%- endcapture -%}

<div class="section-featured-blog" id="section-{{section.id}}" data-section-id="{{section.id}}"{% if enable_slider %} data-section-type="featured-collection"{% endif %}>
  <div class="{% if template == 'index' or template contains 'page' %}{{ layout_class }}{% endif %}">
    <div class="section-wrapper {{items_spacing_row}}">

      {%- if section_heading != blank -%}
        {%- capture heading_css -%}
          {%- render 'snippet-heading' type: 'render-css' config: heading_style_block.settings, classID: sectionID -%}
        {%- endcapture -%}
        <div class="section-header">{{section_heading}}</div>
      {%- endif -%}

      {%- unless blog == blank -%}
        <div class="section-body">
          {%- if enable_slider -%}
          <native-slider class="d-block position-relative" data-autoplay="{{ autoplay }}" data-autoplay-timeout="{{ autoplay_timeout | times: 1000 }}">
          {%- endif -%}
            <div class="slider-container js-slider-container">
              <div class="slider-wrapper position-relative">

                <div class="slider-list{% unless enable_slider %} row{% else %} d-flex{% endunless %}" id="slider-{{section.id}}">
                  {%- for article in blog.articles limit: limit -%}

                    <article class="featured_blog__item{% unless enable_slider %} {{ gridClass }}{% else %} slider-item{% endunless %}">
                      <div class="featured_blog__item-inner">
                        <div class="featured_blog__item-image">
                          <a href="{{ article.url }}">
                            {%- render 'image-style', image: article.image -%}
                          </a>
                        </div>
                        <div class="featured_blog__item-info">
                          {%- if section.settings.visibility_date -%}
                            <span class="featured_blog__item-publish">{{ article.published_at | date: "%b %d, %Y" }}</span>
                          {%- endif -%}
                          
                          <h3 class="featured_blog__item-title">
                            <a href="{{ article.url }}">{{ article.title }}</a>
                          </h3>

                          {%- if section.settings.show_excerpt and article.excerpt_or_content != blank -%}
                            <div class="featured_blog__item-excerpt">{{ article.excerpt_or_content }}</div>
                          {%- endif -%}
                          
                          {%- if section.settings.read_more_btn -%}
                            <a class="featured_blog__item-btn" href="{{ article.url }}">
                              <span>{{ 'general.button.read_more' | t }}</span>
                              {%- render 'svg' type: 'arrow-right' -%}
                            </a>
                          {%- endif -%}
                        </div>
                      </div>
                    </article>
                    
                  {%- endfor -%}
                </div>

                {%- if enable_slider and controls -%}
                  <button class="slider-prev-button" aria-label="Previous">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
                  </button>
                  <button class="slider-next-button" aria-label="Next">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                  </button>
                {%- endif -%}
                {%- if enable_slider and dots -%}
                  <div class="slider-dots"></div>
                {%- endif -%}
              </div>
            </div>
          {%- if enable_slider -%}</native-slider>{%- endif -%}
        </div>
      {%- endunless -%}
    </div>
  </div>
</div>

{%- if enable_slider -%}
<script>
  (function() {
    window.theme = window.theme || {};
    (window.theme.sectionRegister = window.theme.sectionRegister || []).push("featured-collection");
    (window.theme.customElementsList = window.theme.customElementsList || []).push("slider-component");
  })();
</script>
{%- endif -%}
{%- liquid
  assign grid_arr = items_resp | split: ','
  assign grid_desk = grid_arr[0] | default: 2
  assign grid_tab = grid_arr[1] | default: 2
  assign grid_mob = grid_arr[2] | default: 1
-%}
{%- capture section_css -%}
  {{-heading_css-}}
  {{sectionID}} .featured_blog__item-title { font-size: {{ section.settings.blog_post_heading_fs }}px; font-weight: {{ section.settings.blog_post_heading_fw }}; }
  {%- render 'snippet-theme' type: 'section-style', preClassID: sectionID, classID: bg_class, config: section.settings -%}
  {%- if enable_slider -%}
  {{sectionID}} {
    --items-per-row-desk: {{ grid_desk }};
    --items-per-row-tab: {{ grid_tab }};
    --items-per-row-mob: {{ grid_mob }};
    --gap: {{ items_spacing_slider | default: '30px' }};
  }
  {{sectionID}} .slider-list {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: var(--gap);
    margin: 0;
    padding: 10px 5px;
  }
  {{sectionID}} .featured_blog__item.slider-item {
    flex: 0 0 calc((100% - (var(--gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
    scroll-snap-align: start;
    min-width: calc((100% - (var(--gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
  }
  @media (max-width: 991px) {
    {{sectionID}} .featured_blog__item.slider-item {
      flex: 0 0 calc((100% - (var(--gap) * (var(--items-per-row-tab) - 1))) / var(--items-per-row-tab));
      min-width: calc((100% - (var(--gap) * (var(--items-per-row-tab) - 1))) / var(--items-per-row-tab));
    }
  }
  @media (max-width: 767px) {
    {{sectionID}} .featured_blog__item.slider-item {
      flex: 0 0 calc((100% - (var(--gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
      min-width: calc((100% - (var(--gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
    }
  }
  {%- endif -%}
{%- endcapture -%}
{%- style -%}{{section_css | strip | strip_newlines | remove: '  ' }}{%- endstyle -%}
{%- schema -%}
{
  "name": "Featured Blog",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout Mode",
      "default": "boxed",
      "options": [
        {
          "value": "boxed",
          "label": "Boxed"
        },
        {
          "value": "full",
          "label": "Wide"
        }
      ]
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "text",
      "id": "margin",
      "label": "Section Margin",
      "info": "Order: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "padding",
      "label": "Section Padding",
      "info": "Order: Top Right Bottom Left"
    },
    {
      "type": "header",
      "content": "Blog Post Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured blog"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Select Blog"
    },
    {
      "type": "text",
      "id": "items_resp",
      "label": "Items Per Row (Responsive)",
      "default": "2,1",
      "info": "Values for Desktop, Tablet, Mobile separated by commas."
    },
    {
      "type": "checkbox",
      "id": "visibility_date",
      "label": "Show Publication Date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show Article Excerpt"
    },
    {
      "type": "checkbox",
      "id": "read_more_btn",
      "label": "Show 'Read More' Button"
    },
    {
      "type": "range",
      "id": "blog_post_heading_fs",
      "label": "Heading Font Size",
      "step": 1,
      "min": 12,
      "max": 30,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "blog_post_heading_fw",
      "label": "Heading Font Weight",
      "step": 100,
      "min": 100,
      "max": 700,
      "default": 600
    },
    {
      "type": "checkbox",
      "id": "items_spacing",
      "label": "Enable Items Spacing (Gap)",
      "default": false
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Limit Articles",
      "step": 1,
      "min": 1,
      "max": 6,
      "default": 2
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "label": "Enable Slider",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Infinite Loop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "Show Navigation Arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "dots",
      "label": "Show Navigation Dots",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_timeout",
      "label": "Autoplay Timeout (Seconds)",
      "step": 0.1,
      "min": 2,
      "max": 10,
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "heading-style",
      "limit": 1,
      "name": "Heading Style",
      "settings": [
        {
          "type": "select",
          "id": "section_heading_container_align",
          "label": "Text Alignment",
          "options": [
            {
              "value": "auto",
              "label": "Auto"
            },
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "center",
              "label": "Center"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ]
        },
        {
          "type": "text",
          "id": "section_heading_margin",
          "label": "Margin",
          "info": "Order: Top Right Bottom Left"
        },
        {
          "type": "color",
          "id": "section_heading_color",
          "label": "Text Color"
        },
        {
          "type": "text",
          "id": "section_heading_font_size",
          "label": "Font Size",
          "info": "E.g. 24px"
        },
        {
          "type": "range",
          "id": "section_heading_font_weight",
          "label": "Font Weight",
          "step": 100,
          "min": 100,
          "max": 900,
          "default": 600
        },
        {
          "type": "text",
          "id": "section_heading_line_height",
          "label": "Line Height",
          "info": "E.g. 1.5 or 30px"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Blog"
    }
  ]
}
{%- endschema -%}