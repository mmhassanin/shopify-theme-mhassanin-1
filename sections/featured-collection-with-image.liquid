<link rel="stylesheet" href="{{'section-featured-collection-with-image.css' | asset_url}}" media="print" onload="this.media='all'">

{%- liquid
  assign border_radius = section.settings.border_radius
  assign image = section.settings.image
  assign position = section.settings.position
  assign link = section.settings.link
  assign limit = section.settings.limit
  assign enable_slider = true
  assign dots  = section.settings.dots
  assign loop  = section.settings.loop
  assign controls = section.settings.controls
  assign autoplay = section.settings.autoplay
  assign collection = collections[section.settings.collection]
  assign sectionID  = '#section-' | append: section.id
  assign items_resp = section.settings.items_resp
  assign controls_id = '#controls-' | append: section.id
  assign autoplay_timeout = section.settings.autoplay_timeout
  assign heading_style_block = section.blocks | where: 'type' , 'heading-style' | first
  assign slider_id = '#slider-' | append: section.id
  assign items_spacing_slider = '0'

  if border_radius != 'none'
    assign bg_class = ' .section-wrapper'
  else
    assign bg_class = ''
  endif

  assign layout = section.settings.layout
  if layout == 'boxed'
    assign layout_class = 'container'
  else
    assign layout_class = 'container-fluid'
  endif
-%}

{%- capture section_heading -%}
  {%- render 'snippet-heading', type: 'render-html', config: section.settings -%}
{%- endcapture -%}

<div class="section-featured-collection-with-image border-radius-{{ border_radius }}" id="section-{{section.id}}" data-section-id="{{section.id}}"{% if enable_slider %} data-section-type="featured-collection"{% endif %}>
  <div class="{% if template == 'index' or template contains 'page' %}{{ layout_class }}{% endif %}">
    <div class="section-wrapper">
      <div class="row">

        {%- if image and position == 'left' -%}
          <div class="block-image col-lg-6 col-12">
            <div class="block-image-inner">
              <a href="{{ link }}">
                {%- render 'image-style' image: image, limit: 768 -%}
              </a>
            </div>
          </div>
        {%- endif -%}

        <div class="section-body {% if image %}col-lg-6{% else %}col-lg-12{% endif %} col-12">
          {%- if section_heading != blank -%}
            {%- capture heading_css -%}
              {%- render 'snippet-heading' type: 'render-css' config: heading_style_block.settings, classID: sectionID -%}
            {%- endcapture -%}
            <div class="section-header">
              {{section_heading}}
            </div>
          {%- endif -%}

          <div class="block-slider-component">
            {%- if enable_slider -%}
            <native-slider class="d-block position-relative" data-autoplay="{{ autoplay }}" data-autoplay-timeout="{{ autoplay_timeout | times: 1000 }}">
            {%- endif -%}
              <div class="slider-container js-slider-container">
                <div class="slider-wrapper position-relative">
                  <div class="slider-list{% unless enable_slider %} row{% else %} d-flex flex-nowrap{% endunless %}" id="slider-{{section.id}}">
                    {%- for product in collection.products limit: limit -%}
                      <div class="slider-item">
                        {%- render 'product-item' product: product, collection: collection-%}
                      </div>
                    {%- endfor -%}
                  </div>

                  {%- if enable_slider and controls -%}
                    <button class="slider-prev-button" aria-label="Previous">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
                    </button>
                    <button class="slider-next-button" aria-label="Next">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                    </button>
                  {%- endif -%}
                  {%- if enable_slider and dots -%}
                    <div class="slider-dots"></div>
                  {%- endif -%}
                </div>
              </div>
            {%- if enable_slider -%}</native-slider>{%- endif -%}
          </div> 
        </div>

        {%- if image and position == 'right' -%}
          <div class="block-image col-lg-6 col-12">
            <div class="block-image-inner">
              <a href="{{ link }}">
                {%- render 'image-style' image: image, limit: 768 -%}
              </a>
            </div>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>
</div>

{%- liquid
  assign grid_arr = items_resp | split: ','
  assign grid_desk = grid_arr[0] | default: 3
  assign grid_mob = grid_arr[1] | default: 2
-%}
{%- capture section_css -%}
  {{-heading_css-}}
  {%- render 'snippet-theme' type: 'section-style', preClassID: sectionID, classID: bg_class, config: section.settings -%}
  {%- if enable_slider -%}
  {{sectionID}} {
    --items-per-row-desk: {{ grid_desk }};
    --items-per-row-mob: {{ grid_mob }};
    --gap: {{ items_spacing_slider | default: '30px' }};
  }
  {{sectionID}} .slider-list {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: var(--gap);
    margin: 0;
    padding: 10px 5px;
  }
  {{sectionID}} .slider-item {
    flex: 0 0 calc((100% - (var(--gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
    scroll-snap-align: start;
    min-width: calc((100% - (var(--gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
  }
  @media (max-width: 767px) {
    {{sectionID}} .slider-item {
      flex: 0 0 calc((100% - (var(--gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
      min-width: calc((100% - (var(--gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
    }
  }
  {%- endif -%}
{%- endcapture -%}
{%- style -%}{{section_css | strip | strip_newlines | remove: '  ' }}{%- endstyle -%}
{%- schema -%}
{
  "name": "Collection (Image)",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout Mode",
      "default": "boxed",
      "options": [
        {
          "value": "boxed",
          "label": "Boxed"
        },
        {
          "value": "full",
          "label": "Wide"
        }
      ]
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "select",
      "id": "border_radius",
      "label": "t:sections.common.border_radius",
      "default": "none",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        },
        {
          "value": "none",
          "label": "None"
        }
      ]
    },
    {
      "type": "text",
      "id": "margin",
      "label": "Section Margin",
      "info": "Order: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "padding",
      "label": "Section Padding",
      "info": "Order: Top Right Bottom Left"
    },
    {
      "type": "header",
      "content": "t:sections.common.block_product"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "t:sections.common.subtext"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "items_resp",
      "label": "Items Per Row (Responsive)",
      "default": "3,2"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Limit",
      "step": 1,
      "min": 1,
      "max": 8,
      "default": 6
    },
    {
      "type": "header",
      "content": "t:sections.common.block_image"
    },
    {
      "type": "select",
      "id": "position",
      "label": "t:sections.common.position",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.common.image"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:sections.common.link"
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Infinite Loop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "Show Navigation Arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "dots",
      "label": "Show Navigation Dots",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_timeout",
      "label": "Autoplay Timeout (Seconds)",
      "step": 0.1,
      "min": 2,
      "max": 10,
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "heading-style",
      "limit": 1,
      "name": "Heading Style",
      "settings": [
        {
          "type": "text",
          "id": "section_heading_margin",
          "label": "Margin",
          "info": "Order: Top Right Bottom Left"
        },
        {
          "type": "color",
          "id": "section_heading_color",
          "label": "Text Color"
        },
        {
          "type": "text",
          "id": "section_heading_font_size",
          "label": "Font Size",
          "info": "E.g. 24px"
        },
        {
          "type": "range",
          "id": "section_heading_font_weight",
          "label": "Font Weight",
          "step": 100,
          "min": 100,
          "max": 900,
          "default": 600
        },
        {
          "type": "text",
          "id": "section_heading_line_height",
          "label": "Line Height",
          "info": "E.g. 24px"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection (Image)"
    }
  ]
}
{%- endschema -%}