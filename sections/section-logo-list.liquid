<link rel="stylesheet" href="{{'section-logo-list.css' | asset_url}}" media="print" onload="this.media='all'">

{%- liquid
  assign default_color    = 'rgba(0,0,0,0)' 
  assign bg_class         = ''
  assign sectionID        = '#section-' | append: section.id
  assign slider_id        = '#slider-' | append: section.id
  assign controls_id      = '#controls-' | append: section.id
  assign items_resp       = section.settings.items_resp
  assign items_spacing    = section.settings.items_spacing
  assign loop             = section.settings.loop
  assign controls         = section.settings.controls
  assign dots             = section.settings.dots
  assign autoplay         = section.settings.autoplay
  assign autoplay_timeout = section.settings.autoplay_timeout
  assign heading_style_block = section.blocks | where: 'type' , 'heading-style' | first
  assign gallery_blocks = section.blocks | where: 'type', 'block-item'

  assign layout = section.settings.layout
  if layout == 'boxed'
    assign layout_class = 'container'
  else
    assign layout_class = 'container-fluid'
  endif

  if items_spacing
    assign items_spacing_slider = '30px'
  else
    assign items_spacing_slider = '0'
  endif
-%}

{%- capture section_heading -%}
  {%- render 'snippet-heading' type:'render-html' config: section.settings -%}
{%- endcapture -%}

{%- assign items_array = items_resp | split: ',' -%}
{%- assign items_desk = items_array[0] | default: 6 -%}
{%- assign items_tab = items_array[2] | default: 4 -%}
{%- assign items_mob = items_array[3] | default: 3 -%}
{%- assign grid_gap = '0px' -%}
{%- if items_spacing -%}
  {%- assign grid_gap = '30px' -%}
{%- endif -%}

<style>
  #section-{{section.id}} {
    --grid-gap: {{ grid_gap }};
    --items-per-row-desk: {{ items_desk }};
    --items-per-row-tab: {{ items_tab }};
    --items-per-row-mob: {{ items_mob }};
  }
  #section-{{section.id}} .slider-list {
    display: flex;
    gap: var(--grid-gap);
  }
  #section-{{section.id}} .slider-item {
    flex: 0 0 calc((100% - (var(--grid-gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
    max-width: calc((100% - (var(--grid-gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
  }
  @media (max-width: 991px) {
    #section-{{section.id}} .slider-item {
      flex: 0 0 calc((100% - (var(--grid-gap) * (var(--items-per-row-tab) - 1))) / var(--items-per-row-tab));
      max-width: calc((100% - (var(--grid-gap) * (var(--items-per-row-tab) - 1))) / var(--items-per-row-tab));
    }
  }
  @media (max-width: 767px) {
    #section-{{section.id}} .slider-item {
      flex: 0 0 calc((100% - (var(--grid-gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
      max-width: calc((100% - (var(--grid-gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
    }
  }
</style>

<div class="section-logo-list" id="section-{{section.id}}" data-section-id="{{section.id}}" data-section-type="logo-list">
  <div class="{{ layout_class }}">
    <div class="section-wrapper{% unless section.settings.border %} remove-border-section{% endunless %}">
      {%- if section_heading != blank -%}
        {%- capture heading_css -%}
          {%- render 'snippet-heading' type: 'render-css' config: heading_style_block.settings, classID: sectionID -%}
        {%- endcapture -%}
        <div class="section-header">{{section_heading}}</div>
      {%- endif -%}

      <div class="section-body align-items-center">
        <native-slider data-autoplay="{{ autoplay }}" data-autoplay-timeout="{{ autoplay_timeout | default: 5000 }}">
          <div class="slider-header-controls">
            {%- if controls -%}
              <button type="button" class="slider-prev-button" aria-label="Previous">
                {% render 'icon-dir-left' %}
              </button>
              <button type="button" class="slider-next-button" aria-label="Next">
                {% render 'icon-dir-right' %}
              </button>
            {%- endif -%}
          </div>
          <div class="slider-container position-relative">
            <div class="slider-list" id="slider-{{section.id}}">
              {%- for block in gallery_blocks -%}
                {%- liquid
                  assign type  = block.settings.type
                  assign svg   = block.settings.svg
                  assign image = block.settings.image
                  assign link  = block.settings.link
                -%}

                <div class="slider-item logo-item">
                  {%- capture image -%}
                    {%- if type == 'image' -%}
                      {%- render 'image-style' image: image, limit: 200 -%}
                    {%- else -%}
                      {{svg}}
                    {%- endif -%}
                  {%- endcapture -%}

                  <div class="logo-item_inner">
                    {%- if link != blank -%}
                      <a href="{{link}}" aria-label="Logo image">{{image}}</a>
                    {%- else -%}
                      {{image}}
                    {%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
            
            {%- if dots -%}
            <div class="slider-dots"></div>
            {%- endif -%}
          </div>
        </native-slider>
      </div>
    </div>
  </div>
</div>


{%- capture section_css -%}
  {{-heading_css-}}
  {%- render 'snippet-theme' type: 'section-style' config: section.settings, preClassID: sectionID, classID: bg_class -%}
{%- endcapture -%}
{%- style -%}{{section_css | strip | strip_newlines | remove: '  ' }}{%- endstyle -%}

{%- schema -%}
{
  "name": "Logo List",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout Mode",
      "default": "boxed",
      "options": [
        { "value": "boxed", "label": "Boxed" },
        { "value": "full", "label": "Wide" }
      ]
    },
    {
      "type": "text",
      "id": "margin",
      "label": "Section Margin",
      "info": "Order: Top Right Bottom Left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "text",
      "id": "padding",
      "label": "Section Padding",
      "info": "Order: Top Right Bottom Left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "checkbox",
      "id": "border",
      "label": "Enable Section Border",
      "default": true
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Brands We Trust"
    },
    {
      "type": "header",
      "content": "Grid Settings"
    },
    {
      "type": "text",
      "id": "items_resp",
      "label": "Items Per Row (Responsive)",
      "default": "6,5,4,3",
      "info": "Format: Desktop-Large, Desktop, Tablet, Mobile"
    },
    {
      "type": "checkbox",
      "id": "items_spacing",
      "label": "Enable Spacing Between Logos",
      "default": true
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Infinite Loop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "Show Arrow Controls",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "dots",
      "label": "Show Slider Pagination Dots",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_timeout",
      "label": "Autoplay Timeout",
      "step": 0.1,
      "min": 2,
      "max": 10,
      "unit": "s",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "heading-style",
      "limit": 1,
      "name": "Heading Custom Styles",
      "settings": [
        {
          "type": "select",
          "id": "section_heading_container_align",
          "label": "Heading Alignment",
          "options": [
            { "value": "auto", "label": "Auto" },
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ]
        },
        {
          "type": "text",
          "id": "section_heading_margin",
          "label": "Heading Margin",
          "info": "Order: Top Right Bottom Left (e.g. 10px 0 10px 0)"
        },
        {
          "type": "color",
          "id": "section_heading_color",
          "label": "Text Color"
        },
        {
          "type": "text",
          "id": "section_heading_font_size",
          "label": "Font Size",
          "info": "e.g., 24px"
        },
        {
          "type": "range",
          "id": "section_heading_font_weight",
          "label": "Font Weight",
          "step": 100,
          "min": 100,
          "max": 900,
          "default": 600
        },
        {
          "type": "text",
          "id": "section_heading_line_height",
          "label": "Line Height",
          "info": "e.g., 32px"
        }
      ]
    },
    {
      "type": "block-item",
      "name": "Logo Item",
      "settings": [
        {
          "type": "select",
          "id": "type",
          "label": "Media Type",
          "options": [
            { "value": "image", "label": "Upload Image" },
            { "value": "svg", "label": "Raw SVG Code" }
          ]
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (used if Media Type is Image)"
        },
        {
          "type": "html",
          "id": "svg",
          "label": "SVG Code (used if Media Type is SVG)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link destination"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo List",
      "blocks": [
        { "type": "block-item" },
        { "type": "block-item" },
        { "type": "block-item" },
        { "type": "block-item" },
        { "type": "block-item" },
        { "type": "block-item" }
      ]
    }
  ]
}
{%- endschema -%}