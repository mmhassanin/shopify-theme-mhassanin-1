<link rel="stylesheet" href="{{'section-single-product.css' | asset_url}}" media="print" onload="this.media='all'">

{%- liquid
  assign style = section.settings.style
  assign bg_image = section.settings.bg_image
  assign limit = section.settings.limit
  assign enable_slider =section.settings.enable_slider
  assign dots  = section.settings.dots
  assign loop  = section.settings.loop
  assign controls = section.settings.controls
  assign autoplay = section.settings.autoplay
  assign collection = collections[section.settings.collection]
  assign sectionID  = '#section-' | append: section.id
  assign controls_id = '#controls-' | append: section.id
  assign items_spacing = section.settings.items_spacing
  assign autoplay_timeout = section.settings.autoplay_timeout
  assign heading_style_block = section.blocks | where: 'type' , 'heading-style' | first
  assign slider_id = '#slider-' | append: section.id

  assign layout = section.settings.layout
  if layout == 'boxed'
    assign layout_class = 'container'
  else
    assign layout_class = 'container'
  endif

  if style == 3 or style == 4
    assign items_resp = section.settings.items_resp

    if items_spacing
      assign items_spacing_slider = '30px'
    else
      assign items_spacing_slider = '0'
    endif

    if items_spacing == false and enable_slider == false
      assign items_spacing_row = 'no-padding'
    endif

  else
    assign items_resp = '1'
    if enable_slider
      assign items_spacing_slider = '0'
    else
      assign items_spacing_row = 'no-padding'
    endif
  endif
-%}

{%- if layout == 'full' -%}
  {%- assign bg_class = '' -%}
  {%- assign full_width = 'full-width' -%}
  {%- capture bg_wide -%}{%- render 'bg_responsive' image_desk: bg_image, image_mobi: bg_image -%}{%- endcapture -%}
{%- else -%}
  {%- assign bg_class = ' .section-wrapper' -%}
  {%- capture bg_boxed -%}{%- render 'bg_responsive' image_desk: bg_image, image_mobi: bg_image -%}{%- endcapture -%}
{%- endif -%}

{%- capture section_heading -%}
  {%- render 'snippet-heading' type:'render-html' config: section.settings -%}
{%- endcapture -%}

{%- capture gridClass -%}{%- render 'set-item-per-row', value: items_resp -%}{%- endcapture -%}

<div class="section-single-product {{full_width}} {{bg_wide}}" id="section-{{section.id}}" data-section-id="{{section.id}}"{% if enable_slider %} data-section-type="featured-collection"{% endif %}>
  <div class="{{ layout_class }}">
    <div class="section-wrapper {{bg_boxed}} {{ items_spacing_row }}">

      {%- if section_heading != blank -%}
        {%- capture heading_css -%}
          {%- render 'snippet-heading' type: 'render-css' config: heading_style_block.settings, classID: sectionID -%}
        {%- endcapture -%}
        <div class="section-header">{{section_heading}}</div>
      {%- endif -%}

      <div class="section-body single-product-list style-{{ style }}">
        {%- if enable_slider -%}
        <native-slider class="d-block position-relative" data-autoplay="{{ autoplay }}" data-autoplay-timeout="{{ autoplay_timeout | times: 1000 }}">
        {%- endif -%}
          <div class="slider-container js-slider-container">
            <div class="slider-wrapper position-relative">
              <div class="slider-list{% unless enable_slider %} row{% else %} d-flex flex-nowrap{% endunless %}" id="slider-{{section.id}}">
                {%- for block in section.blocks -%}
                  {%- assign _product = block.settings.product -%}
                  {%- unless _product == blank -%}
                    {%- assign product = all_products[_product] -%}
                    <div class="slider-item{% unless enable_slider %} {{ gridClass }}{% endunless %}">
                      {%- render 'single-product-item', product: product -%}
                    </div>
                  {%- endunless -%}
                {%- endfor -%}
              </div>

              {%- if enable_slider and controls -%}
                <button class="slider-prev-button" aria-label="Previous">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
                </button>
                <button class="slider-next-button" aria-label="Next">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                </button>
              {%- endif -%}
              {%- if enable_slider and dots -%}
                <div class="slider-dots"></div>
              {%- endif -%}

            </div>
          </div>
        {%- if enable_slider -%}</native-slider>{%- endif -%}
      </div>
    </div>
  </div>
</div>

{%- liquid
  assign grid_arr = items_resp | split: ','
  assign grid_desk = grid_arr[0] | default: 4
  assign grid_tab = grid_arr[1] | default: 3
  assign grid_mob = grid_arr[2] | default: 2
-%}
{%- capture section_css -%}
  {{-heading_css-}}
  {%- render 'snippet-theme' type: 'section-style', preClassID: sectionID, classID: bg_class, config: section.settings -%}
  {%- if enable_slider -%}
  {{sectionID}} {
    --items-per-row-desk: {{ grid_desk }};
    --items-per-row-tab: {{ grid_tab }};
    --items-per-row-mob: {{ grid_mob }};
    --gap: {{ items_spacing_slider | default: '30px' }};
  }
  {{sectionID}} .slider-list {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: var(--gap);
    margin: 0;
    padding: 10px 5px;
  }
  {{sectionID}} .slider-item {
    flex: 0 0 calc((100% - (var(--gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
    scroll-snap-align: start;
    min-width: calc((100% - (var(--gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
  }
  @media (max-width: 991px) {
    {{sectionID}} .slider-item {
      flex: 0 0 calc((100% - (var(--gap) * (var(--items-per-row-tab) - 1))) / var(--items-per-row-tab));
      min-width: calc((100% - (var(--gap) * (var(--items-per-row-tab) - 1))) / var(--items-per-row-tab));
    }
  }
  @media (max-width: 767px) {
    {{sectionID}} .slider-item {
      flex: 0 0 calc((100% - (var(--gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
      min-width: calc((100% - (var(--gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
    }
  }
  {%- endif -%}
{%- endcapture -%}
{%- style -%}{{section_css | strip | strip_newlines | remove: '  ' }}{%- endstyle -%}
{%- schema -%}
{
  "name": "Single Product",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout Mode",
      "default": "boxed",
      "options": [
        {
          "value": "boxed",
          "label": "Boxed"
        },
        {
          "value": "full",
          "label": "Wide"
        }
      ]
    },
    {
      "type": "range",
      "id": "style",
      "label": "Style",
      "default": 1,
      "min": 1,
      "max": 4
    },
    {
      "type": "text",
      "id": "margin",
      "label": "Section Margin",
      "info": "Order: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "padding",
      "label": "Section Padding",
      "info": "Order: Top Right Bottom Left"
    },
    {
      "type": "header",
      "content": "t:sections.common.background_settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "text",
      "id": "items_resp",
      "label": "Items Per Row (Responsive)",
      "default": "6,5,3,2",
      "info": "t:sections.single-product.settings.only_style_3"
    },
    {
      "type": "checkbox",
      "id": "items_spacing",
      "label": "Enable Items Spacing (Gap)",
      "default": true,
      "info": "t:sections.single-product.settings.only_style_3"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Limit",
      "step": 1,
      "min": 1,
      "max": 20,
      "default": 10
    }, 
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "label": "Enable Slider",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Infinite Loop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "Show Navigation Arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "dots",
      "label": "Show Navigation Dots",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_timeout",
      "label": "Autoplay Timeout (Seconds)",
      "step": 0.1,
      "min": 2,
      "max": 10,
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "heading-style",
      "limit": 1,
      "name": "Heading Style",
      "settings": [
        {
          "type": "select",
          "id": "section_heading_container_align",
          "label": "Alignment",
          "options": [
            {
              "value": "auto",
              "label": "Auto"
            },
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "center",
              "label": "Center"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ]
        },
        {
          "type": "text",
          "id": "section_heading_margin",
          "label": "Margin",
          "info": "Order: Top Right Bottom Left"
        },
        {
          "type": "color",
          "id": "section_heading_color",
          "label": "Text Color"
        },
        {
          "type": "text",
          "id": "section_heading_font_size",
          "label": "Font Size",
          "info": "E.g. 24px"
        },
        {
          "type": "range",
          "id": "section_heading_font_weight",
          "label": "Font Weight",
          "step": 100,
          "min": 100,
          "max": 900,
          "default": 600
        },
        {
          "type": "text",
          "id": "section_heading_line_height",
          "label": "Line Height",
          "info": "E.g. 24px"
        }
      ]
    },
    {
      "type": "product",
      "name": "Block Item",
      "limit": 6,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "t:sections.common.product"
        },
        {
          "type": "header",
          "content": "t:sections.common.textbox",
          "info": "t:sections.single-product.settings.only_style_1"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.common.image"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#000000"
        },
        {
          "type": "text",
          "id": "text_1",
          "label": "t:sections.common.text",
          "default": "LIMITED"
        },
        {
          "type": "text",
          "id": "text_2",
          "label": "t:sections.common.subtext",
          "default": "WEEK DEAL"
        },
        {
          "type": "textarea",
          "id": "text_3",
          "label": "t:sections.common.subtext_2",
          "default": "HURRY UP BEFORE OFFER WILL END"
        },
        {
          "id": "buy_now",
          "type": "text",
          "label": "t:sections.common.button_label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Single Product"
    }
  ]
}
{%- endschema -%}