{%- style -%}
  #Slideshow-{{ section.id }} {
    --slideshow-height: {% if section.settings.slide_height == 'adapt' %}auto{% else %}100vh{% endif %};
    --slide-autoplay-speed: {{ section.settings.autoplay_speed }}s;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  {% if section.settings.slide_height == 'small' %}
    #Slideshow-{{ section.id }} .slideshow__inner { --slideshow-height: 400px; }
  {% elsif section.settings.slide_height == 'medium' %}
    #Slideshow-{{ section.id }} .slideshow__inner { --slideshow-height: 600px; }
  {% elsif section.settings.slide_height == 'large' %}
    #Slideshow-{{ section.id }} .slideshow__inner { --slideshow-height: 800px; }
  {% endif %}

  @media screen and (max-width: 767px) {
    #Slideshow-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | divided_by: 2 }}px;
      padding-bottom: {{ section.settings.padding_bottom | divided_by: 2 }}px;
    }
    #Slideshow-{{ section.id }} .slideshow__inner {
      --slideshow-height: {% if section.settings.mobile_slide_height == 'adapt' %}auto{% elsif section.settings.mobile_slide_height == '250px' %}250px{% elsif section.settings.mobile_slide_height == '300px' %}300px{% elsif section.settings.mobile_slide_height == '400px' %}400px{% elsif section.settings.mobile_slide_height == '100vh' %}100vh{% else %}auto{% endif %};
    }
  }

  /* Scoped Styles for Slideshow */
  #Slideshow-{{ section.id }} .slideshow__inner {
    position: relative;
    width: 100%;
    height: var(--slideshow-height);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  #Slideshow-{{ section.id }}.layout-boxed .slideshow__inner {
    max-width: 1200px;
    margin: 0 auto;
    border-radius: 8px;
  }

  /* Structural wrapper for Slider vs Fade */
  .slideshow__slider {
    display: flex;
    width: 100%;
    height: var(--slideshow-height);
    scrollbar-width: none;
    touch-action: pan-y;
    -webkit-user-select: none;
    user-select: none;
  }
  .slideshow__slider::-webkit-scrollbar {
    display: none;
  }

  /* SLIDE Transition Style */
  .slideshow[data-transition="slide"] .slideshow__slider {
    overflow: visible;
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    will-change: transform;
  }
  .slideshow[data-transition="slide"] .slideshow__slide {
    flex: 0 0 100%;
    position: relative;
  }

  /* FADE Transition Style */
  .slideshow[data-transition="fade"] .slideshow__slider {
    position: relative;
    overflow: hidden;
  }
  .slideshow[data-transition="fade"] .slideshow__slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.8s ease;
    z-index: 1;
    pointer-events: none;
  }
  .slideshow[data-transition="fade"] .slideshow__slide.is-active {
    opacity: 1;
    z-index: 2;
    pointer-events: auto;
  }

  .slideshow__slide {
    display: flex;
    height: 100%;
    overflow: hidden;
  }

  /* Image Handling */
  .slideshow__media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }
  .slideshow__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    pointer-events: none; /* prevent native drag */
    -webkit-user-drag: none;
    -webkit-user-select: none;
    user-select: none;
  }
  .slideshow__media-mobile { display: none; }
  
  @media screen and (max-width: 767px) {
    .slideshow__media-desktop.has-mobile { display: none; }
    .slideshow__media-mobile { display: block; }
  }

  /* Overlay */
  .slideshow__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  /* Content */
  .slideshow__content-wrapper {
    position: relative;
    z-index: 2;
    display: flex;
    width: 100%;
    height: 100%;
    padding: 4rem;
    pointer-events: none;
  }

  @media screen and (max-width: 767px) {
    .slideshow__content-wrapper { padding: 2rem; }
  }

  .slideshow__content {
    display: flex;
    flex-direction: column;
    max-width: 600px;
    padding: 2.5rem;
    border-radius: 8px;
    pointer-events: auto;
    background-color: var(--caption-bg-color, transparent);
    backdrop-filter: blur(var(--caption-blur, 0px));
    -webkit-user-select: none;
    user-select: none;
  }

  .slideshow__content.align-left { text-align: left; align-items: flex-start; }
  .slideshow__content.align-center { text-align: center; align-items: center; }
  .slideshow__content.align-right { text-align: right; align-items: flex-end; }

  .slideshow__content-wrapper.position-top { align-items: flex-start; }
  .slideshow__content-wrapper.position-middle { align-items: center; }
  .slideshow__content-wrapper.position-bottom { align-items: flex-end; }

  .slideshow__content-wrapper.position-left { justify-content: flex-start; }
  .slideshow__content-wrapper.position-center { justify-content: center; }
  .slideshow__content-wrapper.position-right { justify-content: flex-end; }

  .slideshow__heading {
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1rem;
    color: var(--heading-color, #ffffff);
  }
  .slideshow__subheading {
    font-size: clamp(1rem, 2vw, 1.25rem);
    margin-bottom: 2rem;
    color: var(--subheading-color, #f1f1f1);
  }
  .slideshow__btn {
    display: inline-flex;
    padding: 1rem 2rem;
    text-decoration: none;
    font-weight: 600;
    border-radius: 4px;
    transition: transform 0.3s ease, background 0.3s ease, color 0.3s ease, opacity 0.3s ease;
  }

  /* Button Styles */
  .slideshow__btn--solid {
    background-color: var(--button-bg-color, #ffffff);
    color: var(--button-text-color, #000000);
    border: 1px solid var(--button-bg-color, #ffffff);
  }
  .slideshow__btn--solid:hover {
    transform: translateY(-2px);
    opacity: 0.9;
  }
  .slideshow__btn--outline {
    background-color: transparent;
    color: var(--button-bg-color, #ffffff);
    border: 2px solid var(--button-bg-color, #ffffff);
  }
  .slideshow__btn--outline:hover {
    background-color: var(--button-bg-color, #ffffff);
    color: var(--button-text-color, #000000);
    transform: translateY(-2px);
  }

  /* Controls */
  .slideshow__controls {
    position: absolute;
    bottom: {{ section.settings.bullets_bottom_offset }}px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 1.5rem;
    z-index: 3;
    pointer-events: none;
  }

  .slideshow__arrow {
    background: rgba(255, 255, 255, 0.2);
    border: none;
    backdrop-filter: blur(8px);
    color: white;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.3s, transform 0.3s;
    pointer-events: auto;
  }
  .slideshow__arrow:hover { background: rgba(255, 255, 255, 0.4); transform: scale(1.05); }

  .slideshow__pagination {
    display: flex;
    gap: 8px;
    pointer-events: auto;
  }
  .slideshow__dot {
    width: 30px;
    height: 4px;
    background: rgba(255, 255, 255, 0.4);
    border: none;
    cursor: pointer;
    transition: background 0.3s, width 0.3s;
    border-radius: 2px;
  }
  .slideshow__dot[aria-current="true"] {
    background: #ffffff;
    width: 40px;
  }

  /* Animations for internal content */
  .slideshow__slide.is-active .anim-fade-up { animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; }
  .slideshow__slide.is-active .anim-slide-in-left { animation: slideInLeft 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; }
  .slideshow__slide.is-active .anim-zoom-in { animation: zoomIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; }

  /* Delays for children */
  .slideshow__slide.is-active .slideshow__heading { animation-delay: 0.1s; }
  .slideshow__slide.is-active .slideshow__subheading { animation-delay: 0.25s; }
  .slideshow__slide.is-active .slideshow__btn { animation-delay: 0.4s; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideInLeft {
    from { opacity: 0; transform: translateX(-40px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes zoomIn {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }

  /* Adapt to first image logic */
  {% if section.settings.slide_height == 'adapt' or section.settings.mobile_slide_height == 'adapt' %}
    {%- assign first_block = section.blocks.first -%}
    {%- if first_block and first_block.settings.image -%}
       .slideshow__slider { width: 100%; }
       
       {% if section.settings.slide_height == 'adapt' %}
         @media screen and (min-width: 768px) {
           #Slideshow-{{ section.id }} .slideshow__inner {
             height: auto;
           }
           .slideshow__slider { 
             position: relative; 
             padding-bottom: {{ 100 | divided_by: first_block.settings.image.aspect_ratio }}%; 
             height: 0; 
           }
           .slideshow__slide { position: absolute; height: 100%; width: 100%; left: 0; top: 0; }
         }
       {% endif %}

       {% if section.settings.mobile_slide_height == 'adapt' %}
         @media screen and (max-width: 767px) {
           #Slideshow-{{ section.id }} .slideshow__inner {
             height: auto;
           }
           .slideshow__slider { 
             position: relative; 
             {%- assign aspect = first_block.settings.image.aspect_ratio -%}
             {%- if first_block.settings.image_mobile != blank -%}{%- assign aspect = first_block.settings.image_mobile.aspect_ratio -%}{%- endif -%}
             padding-bottom: {{ 100 | divided_by: aspect }}%; 
             height: 0; 
           }
           .slideshow__slide { position: absolute; height: 100%; width: 100%; left: 0; top: 0; }
         }
       {% endif %}
    {%- endif -%}
  {% endif %}
{%- endstyle -%}

<div id="Slideshow-{{ section.id }}" class="slideshow layout-{{ section.settings.layout }}" data-transition="{{ section.settings.transition }}" data-autoplay="{{ section.settings.autoplay }}" data-autoplay-speed="{{ section.settings.autoplay_speed | times: 1000 }}">
  <div class="slideshow__inner">
    <div class="slideshow__slider" role="region" aria-roledescription="carousel" aria-label="Slideshow">
      {%- for block in section.blocks -%}
        {%- liquid
          if block.settings.caption_bg_opacity > 0
            assign caption_rgb = block.settings.caption_bg_color | color_to_rgb | remove: 'rgb(' | remove: ')'
            assign caption_rgba = 'rgba(' | append: caption_rgb | append: ', ' | append: block.settings.caption_bg_opacity | divided_by: 100.0 | append: ')'
            assign caption_blur = '8px'
          else
            assign caption_rgba = 'transparent'
            assign caption_blur = '0px'
          endif
        -%}
        
        <div class="slideshow__slide {% if forloop.first %}is-active{% endif %}" data-slide-index="{{ forloop.index0 }}" data-block-id="{{ block.id }}" {{ block.shopify_attributes }} 
             style="--heading-color: {{ block.settings.heading_color }}; 
                    --subheading-color: {{ block.settings.subheading_color }}; 
                    --button-bg-color: {{ block.settings.button_bg_color }}; 
                    --button-text-color: {{ block.settings.button_text_color }};
                    --caption-bg-color: {{ caption_rgba }};
                    --caption-blur: {{ caption_blur }};">
          
          <!-- Background Media -->
          <div class="slideshow__media slideshow__media-desktop {% if block.settings.image_mobile != blank %}has-mobile{% endif %}">
            {%- assign img_loading = 'lazy' -%}
            {%- assign img_fetch = 'auto' -%}
            {%- if forloop.first -%}
              {%- assign img_loading = 'eager' -%}
              {%- assign img_fetch = 'high' -%}
            {%- endif -%}
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 3840 | image_tag: 
                loading: img_loading, 
                fetchpriority: img_fetch, 
                sizes: '100vw', 
                widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840' 
              }}
            {%- else -%}
              {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>

          {%- if block.settings.image_mobile != blank -%}
            <div class="slideshow__media slideshow__media-mobile">
              {{ block.settings.image_mobile | image_url: width: 750 | image_tag: 
                loading: img_loading, 
                fetchpriority: img_fetch, 
                sizes: '100vw', 
                widths: '375, 550, 750' 
              }}
            </div>
          {%- endif -%}

          <!-- Overlay -->
          <div class="slideshow__overlay" style="background-color: {{ block.settings.overlay_color }}; opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"></div>

          <!-- Content -->
          {%- liquid
            assign position_class_y = block.settings.text_position | split: '-' | first
            assign position_class_x = block.settings.text_position | split: '-' | last
          -%}
          <div class="slideshow__content-wrapper position-{{ position_class_y }} position-{{ position_class_x }}">
            <div class="slideshow__content align-{{ block.settings.text_alignment }}">
              {%- if block.settings.heading != blank -%}
                <h2 class="slideshow__heading anim-{{ block.settings.animation_style }}">{{ block.settings.heading | escape }}</h2>
              {%- endif -%}
              {%- if block.settings.subheading != blank -%}
                <p class="slideshow__subheading anim-{{ block.settings.animation_style }}">{{ block.settings.subheading | escape }}</p>
              {%- endif -%}
              {%- if block.settings.button_label != blank -%}
                <a href="{{ block.settings.button_link }}" class="slideshow__btn slideshow__btn--{{ block.settings.button_style }} anim-{{ block.settings.animation_style }}">{{ block.settings.button_label | escape }}</a>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      {%- if section.settings.show_controls or section.settings.show_pagination -%}
        <div class="slideshow__controls">
          {%- if section.settings.show_controls -%}
            <button class="slideshow__arrow slideshow__arrow--prev" aria-label="Previous slide">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
            </button>
          {%- endif -%}

          {%- if section.settings.show_pagination -%}
            <div class="slideshow__pagination">
              {%- for block in section.blocks -%}
                <button class="slideshow__dot" aria-label="Go to slide {{ forloop.index }}" data-slide-index="{{ forloop.index0 }}" aria-current="{% if forloop.first %}true{% else %}false{% endif %}"></button>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if section.settings.show_controls -%}
            <button class="slideshow__arrow slideshow__arrow--next" aria-label="Next slide">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
            </button>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

<script>
  class ElectroSlider {
    constructor(element) {
      this.container = element;
      this.slider = this.container.querySelector('.slideshow__slider');
      this.slides = Array.from(this.container.querySelectorAll('.slideshow__slide'));
      this.dots = Array.from(this.container.querySelectorAll('.slideshow__dot'));
      this.prevBtn = this.container.querySelector('.slideshow__arrow--prev');
      this.nextBtn = this.container.querySelector('.slideshow__arrow--next');
      
      this.transition = this.container.dataset.transition || 'slide';
      this.autoplay = this.container.dataset.autoplay === 'true';
      this.autoplaySpeed = parseInt(this.container.dataset.autoplaySpeed, 10) || 5000;
      
      this.currentIndex = 0;
      this.autoplayTimer = null;
      
      this.isDragging = false;
      this.startX = 0;
      this.currentX = 0;
      this.threshold = 50;
      
      // Store instance for Theme Editor
      this.container.electroSlider = this;

      if (this.slides.length > 1) {
        this.init();
      }
    }

    init() {
      this.bindEvents();
      this.updateUI();
      if (this.autoplay) this.startAutoplay();
    }

    bindEvents() {
      // Dots
      this.dots.forEach((dot, index) => {
        dot.addEventListener('click', (e) => {
          e.preventDefault();
          this.pauseAutoplay();
          this.goToSlide(index);
          this.resumeAutoplay();
        });
      });

      // Arrows
      if (this.prevBtn) {
        this.prevBtn.addEventListener('click', (e) => {
          e.preventDefault();
          this.pauseAutoplay();
          this.goToPrev();
          this.resumeAutoplay();
        });
      }
      if (this.nextBtn) {
        this.nextBtn.addEventListener('click', (e) => {
          e.preventDefault();
          this.pauseAutoplay();
          this.goToNext();
          this.resumeAutoplay();
        });
      }

      // Mouse Events
      this.slider.addEventListener('mousedown', this.dragStart.bind(this));
      this.slider.addEventListener('mousemove', this.dragMove.bind(this));
      this.slider.addEventListener('mouseup', this.dragEnd.bind(this));
      this.slider.addEventListener('mouseleave', this.dragEnd.bind(this));

      // Touch Events
      this.slider.addEventListener('touchstart', this.dragStart.bind(this), { passive: true });
      this.slider.addEventListener('touchmove', this.dragMove.bind(this), { passive: false });
      this.slider.addEventListener('touchend', this.dragEnd.bind(this));

      // Pause on hover
      this.container.addEventListener('mouseenter', () => this.pauseAutoplay());
      this.container.addEventListener('mouseleave', () => this.resumeAutoplay());
    }

    dragStart(e) {
      if (e.type === 'mousedown') {
        if (e.button !== 0) return; // Only left click
        if (e.target.tagName.toLowerCase() === 'img') e.preventDefault(); // Stop native ghost drag
      }
      this.pauseAutoplay();
      this.isDragging = true;
      this.startX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
      this.slider.style.transition = 'none'; 
    }

    dragMove(e) {
      if (!this.isDragging) return;
      if (e.type.includes('touch') && this.transition === 'slide') e.preventDefault(); // Prevent native scroll only horizontally if possible, but safe here.
      this.currentX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
      const diff = this.currentX - this.startX;

      if (this.transition === 'slide') {
        const slideWidth = this.container.clientWidth;
        const currentTranslate = -(this.currentIndex * slideWidth);
        const newTranslate = currentTranslate + diff;
        this.slider.style.transform = `translateX(${newTranslate}px)`;
      }
    }

    dragEnd(e) {
      if (!this.isDragging) return;
      this.isDragging = false;
      this.slider.style.transition = 'transform 0.5s cubic-bezier(0.25, 1, 0.5, 1)'; 

      const endX = e.type.includes('touch') ? (e.changedTouches[0] ? e.changedTouches[0].clientX : this.currentX) : e.clientX;
      const diff = endX - this.startX;

      if (diff > this.threshold) {
        this.goToPrev();
      } else if (diff < -this.threshold) {
        this.goToNext();
      } else {
        this.updateUI(); // Snap back
      }

      this.resumeAutoplay();
    }

    goToNext() {
      let index = this.currentIndex + 1;
      if (index >= this.slides.length) index = 0;
      this.goToSlide(index);
    }

    goToPrev() {
      let index = this.currentIndex - 1;
      if (index < 0) index = this.slides.length - 1;
      this.goToSlide(index);
    }

    goToSlide(index) {
      this.currentIndex = index;
      this.updateUI();
    }

    updateUI() {
      if (this.transition === 'slide') {
        this.slider.style.transform = `translateX(-${this.currentIndex * 100}%)`;
      }
      
      this.slides.forEach((slide, i) => {
        slide.classList.toggle('is-active', i === this.currentIndex);
      });
      
      this.dots.forEach((dot, i) => {
        dot.setAttribute('aria-current', i === this.currentIndex ? 'true' : 'false');
      });
    }

    startAutoplay() {
      this.pauseAutoplay();
      this.autoplayTimer = setInterval(() => {
        this.goToNext();
      }, this.autoplaySpeed);
    }

    pauseAutoplay() {
      if (this.autoplayTimer) {
        clearInterval(this.autoplayTimer);
        this.autoplayTimer = null;
      }
    }

    resumeAutoplay() {
      if (this.autoplay && !this.isDragging) {
        this.startAutoplay();
      }
    }
  }

  // Initialize all sliders on DOMContentLoaded
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.slideshow').forEach(el => new ElectroSlider(el));
  });

  // Shopify Theme Editor Integration
  document.addEventListener('shopify:section:load', (e) => {
    const newSection = e.target.querySelector('.slideshow');
    if (newSection) new ElectroSlider(newSection);
  });

  document.addEventListener('shopify:block:select', (e) => {
    const sectionEl = e.target.closest('.slideshow');
    if (!sectionEl || !sectionEl.electroSlider) return;
    
    const sliderInstance = sectionEl.electroSlider;
    const blockId = e.detail.blockId;
    const blockIndex = sliderInstance.slides.findIndex(s => s.dataset.blockId === blockId);
    
    if (blockIndex !== -1) {
      sliderInstance.pauseAutoplay();
      sliderInstance.goToSlide(blockIndex);
    }
  });
</script>

{% schema %}
{
  "name": "Slideshow",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout Settings",
      "default": "full",
      "options": [
        { "value": "full", "label": "Full Width" },
        { "value": "boxed", "label": "Boxed" }
      ]
    },
    {
      "type": "select",
      "id": "transition",
      "label": "Transition Effect",
      "default": "slide",
      "options": [
        { "value": "slide", "label": "Slide" },
        { "value": "fade", "label": "Fade" }
      ]
    },
    {
      "type": "header",
      "content": "Height Settings"
    },
    {
      "type": "select",
      "id": "slide_height",
      "label": "Desktop Slide Height",
      "default": "adapt",
      "options": [
        { "value": "adapt", "label": "Adapt to first image" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full", "label": "Full Screen (100vh)" }
      ]
    },
    {
      "type": "select",
      "id": "mobile_slide_height",
      "label": "Mobile Slide Height",
      "default": "adapt",
      "options": [
        { "value": "adapt", "label": "Adapt to first image" },
