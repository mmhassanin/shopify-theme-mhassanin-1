<link rel="stylesheet" href="{{'left-column.css' | asset_url}}" media="all">

<div class="left-column-container">
  {%- for block in section.blocks -%}
    {% case block.type %}

      {%- when 'menu' -%}
        {%- render 'sidebar-snippet', type: 'menu', block: block -%}

      {%- when 'banner' -%}
        {%- render 'sidebar-snippet', type: 'banner', block: block -%}
  
      {%- when 'products-listing' -%}
        {%- render 'sidebar-snippet', type: 'products-listing', block: block -%}
  
      {%- when 'service' -%}
        {%- render 'sidebar-snippet', type: 'service', block: block -%}
  
      {%- when 'products-grid' -%}
        {%- render 'sidebar-snippet', type: 'products-grid', block: block -%}
  
      {%- when 'blog' -%}
        {%- render 'sidebar-snippet', type: 'blog-post', block: block -%}

    {% endcase %}
  {%- endfor -%}
</div>

