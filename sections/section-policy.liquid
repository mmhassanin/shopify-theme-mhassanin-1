<link rel="stylesheet" href="{{'section-policy.css' | asset_url}}" media="print" onload="this.media='all'">

{%- liquid
  assign bg_class = ''
  assign dots  = section.settings.dots
  assign loop  = section.settings.loop
  assign controls = section.settings.controls
  assign autoplay = section.settings.autoplay
  assign sectionID  = '#section-' | append: section.id
  assign items_resp = section.settings.items_resp
  assign controls_id = '#controls-' | append: section.id
  assign items_spacing = '0'
  assign autoplay_timeout = section.settings.autoplay_timeout
  assign slider_id = '#slider-' | append: section.id

  assign layout = section.settings.layout
  if layout == 'boxed'
    assign layout_class = 'container'
  else
    assign layout_class = 'container-fluid'
  endif
-%}

{%- capture gridClass -%}{%- render 'set-item-per-row', value: items_resp -%}{%- endcapture -%}

<div class="section-policy" id="section-{{section.id}}" data-section-id="{{section.id}}" data-section-type="featured-collection">
  <div class="{% if template == 'index' or template contains 'page' %}{{ layout_class }}{% endif %}">
    <div class="section-wrapper{% unless section.settings.border %} remove-border{% endunless %}">

      <div class="section-body policy-list style-{{ section.settings.style }}">
        <native-slider class="d-block position-relative" data-autoplay="{{ autoplay }}" data-autoplay-timeout="{{ autoplay_timeout | times: 1000 }}">
          <div class="slider-container js-slider-container">
            <div class="slider-wrapper position-relative">
              <div class="slider-list d-flex flex-nowrap" id="slider-{{section.id}}">
                {%- for block in section.blocks -%}
                  {%- assign svg = block.settings.svg -%}
                  {%- assign image = block.settings.image -%}
                  {%- assign heading = block.settings.heading -%}
                  {%- assign subheading = block.settings.subheading -%}

                  <div class="slider-item">
                    <div class="item">
                      {%- if svg != blank or image != blank -%}
                        <div class="image">
                          {%- if svg == blank -%}
                          {%- render 'image-style' image: image, limit: 100 -%}
                          {%- else -%}
                          {{ svg }}
                          {%- endif -%}
                        </div>
                      {%- endif -%}

                      <div class="text">
                        {%- unless heading == blank -%}<h6>{{ heading }}</h6>{%- endunless -%}
                        {%- unless subheading == blank -%}<span>{{ subheading }}</span>{%- endunless -%}
                      </div>
                    </div>
                  </div>

                {%- endfor -%}
              </div>

              {%- if controls -%}
                <button class="slider-prev-button" aria-label="Previous">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
                </button>
                <button class="slider-next-button" aria-label="Next">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                </button>
              {%- endif -%}
              {%- if dots -%}
                <div class="slider-dots"></div>
              {%- endif -%}

            </div>
          </div>
        </native-slider>
      </div>
    </div>
  </div>
</div>

{%- liquid
  assign grid_arr = items_resp | split: ','
  assign grid_desk = grid_arr[0] | default: 4
  assign grid_tab = grid_arr[2] | default: 3
  assign grid_mob = grid_arr[3] | default: 1
-%}
{%- capture section_css -%}
{%- render 'snippet-theme' type: 'section-style', preClassID: sectionID, classID: bg_class, config: section.settings -%}
  {{sectionID}} {
    --items-per-row-desk: {{ grid_desk }};
    --items-per-row-tab: {{ grid_tab }};
    --items-per-row-mob: {{ grid_mob }};
    --gap: 0px;
  }
  {{sectionID}} .slider-list {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: var(--gap);
    margin: 0;
    padding: 10px 5px;
  }
  {{sectionID}} .slider-item {
    flex: 0 0 calc((100% - (var(--gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
    scroll-snap-align: start;
    min-width: calc((100% - (var(--gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
  }
  @media (max-width: 991px) {
    {{sectionID}} .slider-item {
      flex: 0 0 calc((100% - (var(--gap) * (var(--items-per-row-tab) - 1))) / var(--items-per-row-tab));
      min-width: calc((100% - (var(--gap) * (var(--items-per-row-tab) - 1))) / var(--items-per-row-tab));
    }
  }
  @media (max-width: 767px) {
    {{sectionID}} .slider-item {
      flex: 0 0 calc((100% - (var(--gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
      min-width: calc((100% - (var(--gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
    }
  }
{%- endcapture -%}
{%- style -%}{{section_css | strip | strip_newlines | remove: '  ' }}{%- endstyle -%}
{%- schema -%}
{
  "name": "Policy Section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout Mode",
      "default": "boxed",
      "options": [
        {
          "value": "boxed",
          "label": "Boxed"
        },
        {
          "value": "full",
          "label": "Wide"
        }
      ]
    },
    {
      "type": "text",
      "id": "margin",
      "label": "Section Margin",
      "info": "Order: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "padding",
      "label": "Section Padding",
      "info": "Order: Top Right Bottom Left"
    },
    {
      "type": "checkbox",
      "id": "border",
      "label": "Border",
      "default" : true
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "text",
      "id": "items_resp",
      "label": "Items Per Row (Responsive)",
      "default": "6,5,3,2"
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Infinite Loop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "Show Navigation Arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "dots",
      "label": "Show Navigation Dots",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_timeout",
      "label": "Autoplay Timeout (Seconds)",
      "step": 0.1,
      "min": 2,
      "max": 10,
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "image",
      "name": "Block Item",
      "settings": [
        {
          "type": "textarea",
          "id": "svg",
          "label": "t:sections.common.svg"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.common.image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "t:sections.common.subheading",
          "default": "Subheading"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Policy Section"
    }
  ]
}
{%- endschema -%}