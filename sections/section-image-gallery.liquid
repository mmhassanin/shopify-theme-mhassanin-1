<link rel="stylesheet" href="{{'section-image-gallery.css' | asset_url}}" media="print" onload="this.media='all'">

{%- liquid
  assign bg_class = ''
  assign border_top = section.settings.border_top
  assign round_image = section.settings.round_image
  assign enable_slider = section.settings.enable_slider
  assign dots  = section.settings.dots
  assign loop  = section.settings.loop
  assign controls = section.settings.controls
  assign autoplay = section.settings.autoplay
  assign sectionID = '#section-' | append: section.id
  assign items_resp = section.settings.items_resp
  assign controls_id = '#controls-' | append: section.id
  assign autoplay_timeout = section.settings.autoplay_timeout
  assign block_style = section.blocks | where: 'type' , 'block-style' | first
  assign items_spacing  = section.settings.items_spacing
  assign gallery_blocks = section.blocks | where: 'type', 'block-item'
  assign limit = gallery_blocks.size
  assign slider_id = '#slider-' | append: section.id

  assign layout = section.settings.layout
  if layout == 'boxed'
    assign layout_class = 'container'
  else
    assign layout_class = 'container-fluid'
  endif

  if items_spacing
    assign items_spacing_slider = '30px'
  else
    assign items_spacing_slider = '0'
  endif

  if items_spacing == false and enable_slider == false
    assign items_spacing_row = 'no-padding'
  endif
-%}

<div class="section-image-gallery {{ border_top }}" id="section-{{section.id}}" data-section-id="{{section.id}}"{% if enable_slider %} data-section-type="featured-collection"{% endif %}>
  <div class="{% if template == 'index' or template contains 'page' %}{{ layout_class }}{% endif %}">
    <div class="section-wrapper {{ items_spacing_row }}">
      <div class="section-body{% if round_image %} round-image{% endif %}">

        {%- if enable_slider -%}
          <native-slider class="d-block position-relative" data-autoplay="{{ autoplay }}" data-autoplay-timeout="{{ autoplay_timeout | times: 1000 }}">
            <div class="slider-container js-slider-container">
              <div class="slider-wrapper position-relative">
                <div class="slider-list d-flex" id="slider-{{section.id}}">
                  {%- for block in gallery_blocks -%}
                    {%- liquid
                      assign link = block.settings.link
                      assign image = block.settings.image
                      assign title = block.settings.heading
                      assign subtext = block.settings.subtext
                    -%}
                    <div class="slider-item">
                      <div class="image-gallery_item"> 
                        <a href="{{ link }}" aria-label="Image gallery">
                          {%- render 'image-style' image: image, limit: 992 -%} 
                        </a>
                        <div class="textbox">
                          {%- if title != blank -%}<a href="{{ link }}"><span class="image-gallery_title">{{title}}</span></a>{%- endif -%}
                          {%- if subtext != blank -%}<span class="image-gallery_subtext">{{subtext}}</span>{%- endif -%}
                        </div>
                      </div>
                    </div>
                  {%- endfor -%}
                </div>

                {%- if controls -%}
                  <button class="slider-prev-button" aria-label="Previous">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
                  </button>
                  <button class="slider-next-button" aria-label="Next">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                  </button>
                {%- endif -%}
                {%- if dots -%}
                  <div class="slider-dots"></div>
                {%- endif -%}
              </div>
            </div>
          </native-slider>

        {%- else -%}
          <div class="image-gallery-grid d-flex">
            {%- for block in gallery_blocks -%}
              {%- liquid
                assign link = block.settings.link
                assign image = block.settings.image
                assign title = block.settings.heading
                assign subtext = block.settings.subtext
              -%}
              <div class="image-gallery_item">
                <a href="{{ link }}" aria-label="Image gallery">
                  {%- render 'image-style' image: image, limit: 992 -%} 
                </a>
                <div class="textbox">
                  {%- if title != blank -%}<a href="{{ link }}"><span class="image-gallery_title">{{title}}</span></a>{%- endif -%}
                  {%- if subtext != blank -%}<span class="image-gallery_subtext">{{subtext}}</span>{%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>
</div>

{%- if enable_slider -%}
<script>
  window.theme = window.theme || {};
  if(!!window.theme.sectionRegister){
    !window.theme.sectionRegister.includes("featured-collection") && (window.theme.sectionRegister = [...window.theme.sectionRegister, "featured-collection"]);
  }else{
    window.theme.sectionRegister = ["featured-collection"];
  }
</script>

<script>
  window.theme = window.theme || {};
  if(!!window.theme.customElementsList){
    !window.theme.customElementsList.includes("slider-component") && (window.theme.customElementsList = [...window.theme.customElementsList, "slider-component"]);
  }else{
    window.theme.customElementsList = ["slider-component"];
  }
</script>
{%- endif -%}

{%- liquid
  assign grid_arr = items_resp | split: ','
  assign grid_desk = grid_arr[0] | default: 4
  assign grid_tab = grid_arr[1] | default: 3
  assign grid_mob = grid_arr[2] | default: 2
-%}
{%- capture section_css -%}
  {%- render 'snippet-theme' type: 'section-style', config: section.settings, preClassID: sectionID, classID: bg_class -%}
  {{sectionID}} {
    --items-per-row-desk: {{ grid_desk }};
    --items-per-row-tab: {{ grid_tab }};
    --items-per-row-mob: {{ grid_mob }};
    --gap: {{ items_spacing_slider | default: '30px' }};
  }
  {{sectionID}} .slider-list, {{sectionID}} .image-gallery-grid {
    display: flex;
    gap: var(--gap);
    margin: 0;
  }
  {{sectionID}} .slider-list {
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 10px 5px;
  }
  {{sectionID}} .image-gallery-grid {
    flex-wrap: wrap;
    padding: 10px 0;
  }
  {{sectionID}} .slider-item, {{sectionID}} .image-gallery-grid .image-gallery_item {
    flex: 0 0 calc((100% - (var(--gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
    min-width: calc((100% - (var(--gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
  }
  {{sectionID}} .slider-item { scroll-snap-align: start; }
  @media (max-width: 991px) {
    {{sectionID}} .slider-item, {{sectionID}} .image-gallery-grid .image-gallery_item {
      flex: 0 0 calc((100% - (var(--gap) * (var(--items-per-row-tab) - 1))) / var(--items-per-row-tab));
      min-width: calc((100% - (var(--gap) * (var(--items-per-row-tab) - 1))) / var(--items-per-row-tab));
    }
  }
  @media (max-width: 767px) {
    {{sectionID}} .slider-item, {{sectionID}} .image-gallery-grid .image-gallery_item {
      flex: 0 0 calc((100% - (var(--gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
      min-width: calc((100% - (var(--gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
    }
  }

  {%- if block_style != blank -%}
    {%- liquid
      assign title_color = block_style.settings.title_color | default: default_color
      assign subtext_color = block_style.settings.subtext_color | default: default_color
      assign title_font_size = block_style.settings.title_font_size
      assign title_font_weight = block_style.settings.title_font_weight
      assign title_line_height = block_style.settings.title_line_height
      assign subtext_font_size = block_style.settings.subtext_font_size
      assign subtext_font_weight = block_style.settings.subtext_font_weight
      assign subtext_line_height = block_style.settings.subtext_line_height
    -%}

    {%- render 'css-responsive' preClassID: sectionID, classID: ' .image-gallery_title',
      value_1: title_color, property_1: 'color'
      value_2: title_font_size, property_2: 'font-size'
      value_3: title_font_weight, property_3: 'font-weight'
      value_4: title_line_height, property_4: 'line-height'
      -%}
    {%- render 'css-responsive' preClassID: sectionID, classID: ' .image-gallery_subtext',
      value_1: subtext_color, property_1: 'color'
      value_2: subtext_font_size, property_2: 'font-size'
      value_3: subtext_font_weight, property_3: 'font-weight'
      value_4: subtext_line_height, property_4: 'line-height'
      -%}
  {%- endif -%}
{%- endcapture -%}

{%- style -%}{{section_css | strip | strip_newlines | remove: '  '}}{%- endstyle -%}

{%- schema -%}
  {
    "name" : "Image Gallery",
    "tag" : "section",
    "disabled_on": {
      "groups": ["header", "footer"]
    },
    "settings" : [
      {
        "type": "header",
        "content": "General Settings"
      },
      {
        "type": "select",
        "id": "layout",
        "label": "Layout Mode",
        "default": "boxed",
        "options": [
          {
            "value": "boxed",
            "label": "Boxed"
          },
          {
            "value": "full",
            "label": "Wide"
          }
        ]
      },
      {
        "type": "select",
        "id": "border_top",
        "label": "Top Border Style",
        "default": "border-top-none",
        "options": [
          {
            "value": "border-top",
            "label": "Normal"
          },
          {
            "value": "border-top-fw",
            "label": "Full width"
          },
          {
            "value": "border-top-none",
            "label": "None"
          }
        ]
      },
      {
        "type": "checkbox",
        "id": "round_image",
        "label": "Make Images Round"
      },
      {
        "type": "color",
        "id": "bg_color",
        "label": "Background Color"
      },
      {
        "type": "text",
        "id": "margin",
        "label": "Section Margin",
        "info": "Order: Top Right Bottom Left"
      },
      {
        "type": "text",
        "id": "padding",
        "label": "Section Padding",
        "info": "Order: Top Right Bottom Left"
      },
      {
        "type": "header",
        "content": "Grid Settings"
      },
      {
        "type": "text",
        "id": "items_resp",
        "label": "Items Per Row (Responsive)",
        "default": "4,2",
        "info": "Desktop, Tablet, Mobile separated by commas"
      },
      {
        "type": "checkbox",
        "id": "items_spacing",
        "label": "Enable Items Spacing (Gap)",
        "default" : true
      },
      {
        "type": "header",
        "content": "Slider Settings"
      },
      {
        "type": "checkbox",
        "id": "enable_slider",
        "label": "Enable Slider",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "loop",
        "label": "Infinite Loop",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "controls",
        "label": "Show Navigation Arrows",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "dots",
        "label": "Show Navigation Dots",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "autoplay",
        "label": "Enable Autoplay",
        "default": false
      },
      {
        "type": "range",
        "id": "autoplay_timeout",
        "label": "Autoplay Timeout (Seconds)",
        "step": 0.1,
        "min": 2,
        "max": 10,
        "default": 4
      }
    ],
    "blocks": [
      {
        "type": "@app"
      },
      {
        "type" : "block-item",
        "name" : "Image gallery item",
        "settings" : [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Heading"
          },
          {
            "type": "textarea",
            "id": "subtext",
            "label": "Subtext"
          },
          {
            "type": "url",
            "id": "link",
            "label": "Link"
          }
        ]
      },
      {
        "type" : "block-style",
        "limit": 1,
        "name" : "Text Styles",
        "settings" : [
          {
            "type": "header",
            "content": "Heading Style"
          },
          {
            "type": "color",
            "id": "title_color",
            "label": "Text Color"
          },
          {
            "type": "text",
            "id": "title_font_size",
            "label": "Font Size"
          },
          {
            "type" : "range",
            "id": "title_font_weight",
            "label": "Font Weight",
            "step": 100,
            "min" : 100,
            "max" : 900,
            "default" : 600
          },
          {
            "type": "text",
            "id": "title_line_height",
            "label": "Line Height"
          },
          {
            "type": "header",
            "content": "Subtext Style"
          },
          {
            "type": "color",
            "id": "subtext_color",
            "label": "Text Color"
          },
          {
            "type": "text",
            "id": "subtext_font_size",
            "label": "Font Size"
          },
          {
            "type" : "range",
            "id": "subtext_font_weight",
            "label": "Font Weight",
            "step": 100,
            "min" : 100,
            "max" : 900,
            "default" : 400
          },
          {
            "type": "text",
            "id": "subtext_line_height",
            "label": "Line Height"
          }
        ]
      }
    ],
    "presets": [
      {
        "name" : "Image Gallery",
        "blocks" : [
          {
            "type" : "block-item"
          },
           {
            "type" : "block-item"
          },
           {
            "type" : "block-item"
          }
        ]
      }
    ]
  }
{%- endschema -%}