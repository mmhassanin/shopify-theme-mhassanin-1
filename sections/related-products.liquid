{%- liquid
  assign bg_class = ''
  assign loop  = section.settings.loop
  assign dots  = section.settings.dots
  assign limit = section.settings.limit
  assign autoplay = section.settings.autoplay
  assign controls = section.settings.controls
  assign section_id = '#section-' | append: section.id
  assign slider_id = '#slider-' | append: section.id
  assign items_resp  = section.settings.items_resp
  assign controls_id = '#controls-' | append: section.id
  assign source_from = section.settings.source_from
  assign items_spacing = section.settings.items_spacing
  assign autoplay_timeout = section.settings.autoplay_timeout
  assign static_collection = section.settings.static_collection
  assign heading_style_block = section.blocks | where: 'type', 'heading-style'  | first
-%}

{%- capture heading_section -%}
  {%- render 'snippet-heading' type: 'render-html',config: section.settings -%}
{%- endcapture -%}

{%- capture items_list -%}
  {%- liquid
    if source_from == 'current-collection'
    assign collection = product.collections | first
    else
    assign collection = static_collection
    endif
    assign total_item = limit
  -%}
  {%- for p in collection.products limit: limit -%}
    {%- if p == product -%}{%- continue -%}{%- endif -%}
    <div class="slider-item">
      {%- render 'product-item' product: p -%}
    </div>
  {%- endfor -%}
{%- endcapture -%}

<div class="secion-related-products{% if items_list == blank -%} d-none {%- endif -%}" id="section-{{section.id}}" data-section-id="{{section.id}}" data-section-type="related-products" data-source="{{source_from}}">

  <div class="section-wrapper">
    {%- if heading_section != blank -%}
      {%- capture heading_css -%}
        {%- render 'snippet-heading' type: 'render-css' classID: section_id, config: heading_style_block.settings -%}
      {%- endcapture -%}
      <div class="section-header">{{heading_section}}</div>
    {%- endif -%}

    <div class="section-body">
      <native-slider class="d-block position-relative" data-autoplay="{{ section.settings.autoplay }}" data-autoplay-timeout="{{ section.settings.autoplay_timeout | times: 1000 }}">
        <div class="slider-container">
          <div class="slider-wrapper position-relative">
            <div class="slider-list d-flex" id="slider-{{section.id}}">
              {{items_list}}
            </div>

            {%- if controls -%}
              <button class="slider-prev-button" aria-label="Previous">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
              </button>
              <button class="slider-next-button" aria-label="Next">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </button>
            {%- endif -%}

            {%- if dots -%}
              <div class="slider-dots"></div>
            {%- endif -%}
          </div>
        </div>
      </native-slider>
    </div>
  </div>

</div>
<script>
  (() => {
    window.theme = window.theme || {};
    (window.theme.sectionRegister = window.theme.sectionRegister || []).push("related-products");
    (window.theme.customElementsList = window.theme.customElementsList || []).push('slider-component');
  })();
</script>

{%- liquid
  assign grid_arr = items_resp | split: ','
  assign grid_desk = grid_arr[0] | default: 4
  assign grid_tab = grid_arr[1] | default: 3
  assign grid_mob = grid_arr[2] | default: 2
-%}
{%- style -%}
  #section-{{section.id}} {
    --items-per-row-desk: {{ grid_desk }};
    --items-per-row-tab: {{ grid_tab }};
    --items-per-row-mob: {{ grid_mob }};
    --gap: {{ items_spacing | default: '30px' }};
  }
  #section-{{section.id}} .slider-list {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: var(--gap);
    margin: 0;
    padding: 10px 5px;
  }
  #section-{{section.id}} .slider-item {
    flex: 0 0 calc((100% - (var(--gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
    scroll-snap-align: start;
    min-width: calc((100% - (var(--gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
  }
  @media (max-width: 991px) {
    #section-{{section.id}} .slider-item {
      flex: 0 0 calc((100% - (var(--gap) * (var(--items-per-row-tab) - 1))) / var(--items-per-row-tab));
      min-width: calc((100% - (var(--gap) * (var(--items-per-row-tab) - 1))) / var(--items-per-row-tab));
    }
  }
  @media (max-width: 767px) {
    #section-{{section.id}} .slider-item {
      flex: 0 0 calc((100% - (var(--gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
      min-width: calc((100% - (var(--gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
    }
  }

  {{heading_css}}
  {%- render 'snippet-theme' type: 'section-style', preClassID: section_id, classID: bg_class, config: section.settings -%}
{%- endstyle -%}

{%- schema -%}
{
  "name": "Related Products",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    }, 
    {
      "type": "text",
      "id": "margin",
      "label": "Section Margin",
      "info": "Order: Top Right Bottom Left (e.g. 10px 0 20px 0)"
    },
    {
      "type": "text",
      "id": "padding",
      "label": "Section Padding",
      "info": "Order: Top Right Bottom Left"
    },
    {
      "type": "header",
      "content": "Grid Settings"
    },
    {
      "type": "text",
      "id": "items_resp",
      "label": "Items Per Row (Responsive)",
      "default": "4,3,2",
      "info": "Values for Desktop, Tablet, Mobile separated by commas."
    },
    {
      "type": "text",
      "id": "items_spacing",
      "label": "Items Spacing (Gap)",
      "default": "30px"
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default" : "Related products"
    },
    {
      "type": "select",
      "id": "source_from",
      "label": "Source From",
      "options": [
        {
          "value": "current-collection",
          "label": "Current Collection"
        },
        {
          "value": "static-collection",
          "label": "Static Collection"
        }
      ],
      "default" : "current-collection"
    },
    {
      "type": "collection",
      "id": "static_collection",
      "label": "Static Collection (Select)"
    },
    {
      "type" : "range",
      "id": "limit",
      "label": "Limit Products",
      "step": 1,
      "min" : 4,
      "max" : 20,
      "default" : 8
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Infinite Loop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "Show Navigation Arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "dots",
      "label": "Show Navigation Dots",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_timeout",
      "label": "Autoplay Timeout (Seconds)",
      "step": 0.1,
      "min": 2,
      "max": 10,
      "default": 4
    }
  ],
  "blocks" : [
    {
      "type": "@app"
    },
    {
      "type": "heading-style",
      "limit": 1,
      "name": "Heading Style",
      "settings": [
        {
          "type": "select",
          "id": "section_heading_container_align",
          "label": "Text Alignment",
          "options": [
            {
              "value": "auto",
              "label": "Auto"
            },
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "center",
              "label": "Center"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ]
        },
        {
          "type": "text",
          "id": "section_heading_margin",
          "label": "Margin",
          "info": "Order: Top Right Bottom Left"
        },
        {
          "type": "color",
          "id": "section_heading_color",
          "label": "Text Color"
        },
        {
          "type": "text",
          "id": "section_heading_font_size",
          "label": "Font Size",
          "info": "E.g. 24px"
        },
        {
          "type": "range",
          "id": "section_heading_font_weight",
          "label": "Font Weight",
          "step": 100,
          "min": 100,
          "max": 900,
          "default": 600
        },
        {
          "type": "text",
          "id": "section_heading_line_height",
          "label": "Line Height",
          "info": "E.g. 1.5 or 30px"
        }
      ]
    }
  ]
}
{%- endschema -%}