<link rel="stylesheet" href="{{'section-product-tab-v1.css' | asset_url}}" media="print" onload="this.media='all'">

{%- liquid
  assign border_radius = section.settings.border_radius
  assign limit = section.settings.limit
  assign enable_slider =section.settings.enable_slider
  assign dots  = section.settings.dots
  assign loop  = section.settings.loop
  assign controls = section.settings.controls
  assign controls_position = section.settings.controls_position
  assign autoplay = section.settings.autoplay
  assign _collection = section.blocks | where: 'type' , 'product' | first 
  assign collection = collections[_collection.settings.collection]
  assign sectionID  = '#section-' | append: section.id
  assign items_resp = section.settings.items_resp
  assign controls_id = '#controls-' | append: section.id
  assign items_spacing = section.settings.items_spacing
  assign tab_heading_vertical = section.settings.tab_heading_vertical
  assign alignment_tab_title = section.settings.alignment_tab_title
  assign tab_title_style = section.settings.tab_title_style
  assign heading_style_block = section.blocks | where: 'type' , 'heading-style' | first
  assign slider_id = '#slider-' | append: section.id

  assign layout = section.settings.layout
  if layout == 'boxed'
    assign layout_class = 'container'
  else
    assign layout_class = 'container-fluid'
  endif

  if border_radius
    assign bg_class = ' .section-wrapper'
  else
    assign bg_class = ''
  endif

  if items_spacing == false
    assign items_spacing_row = 'no-padding'
    assign items_spacing_slider = '0'
  else
     assign items_spacing_slider = '30px'
  endif
-%}

{%- assign style= '' -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'special-product' -%}
    {%- assign style= block.settings.style -%}
    {%- assign special_style = block.settings.image_special_style -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- capture section_heading -%}
  {%- render 'snippet-heading' type:'render-html' config: section.settings -%}
{%- endcapture -%}

{%- assign items_array = items_resp | split: ',' -%}
{%- assign items_desk = items_array[0] | default: 4 -%}
{%- assign items_tab = items_array[2] | default: 3 -%}
{%- assign items_mob = items_array[3] | default: 2 -%}
{%- assign grid_gap = '0px' -%}
{%- if items_spacing -%}
  {%- assign grid_gap = '30px' -%}
{%- endif -%}

<style>
  #section-{{section.id}} {
    --grid-gap: {{ grid_gap }};
    --items-per-row-desk: {{ items_desk }};
    --items-per-row-tab: {{ items_tab }};
    --items-per-row-mob: {{ items_mob }};
  }
  #section-{{section.id}} .slider-list {
    display: flex;
    gap: var(--grid-gap);
  }
  #section-{{section.id}} .slider-item {
    flex: 0 0 calc((100% - (var(--grid-gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
    max-width: calc((100% - (var(--grid-gap) * (var(--items-per-row-desk) - 1))) / var(--items-per-row-desk));
  }
  @media (max-width: 991px) {
    #section-{{section.id}} .slider-item {
      flex: 0 0 calc((100% - (var(--grid-gap) * (var(--items-per-row-tab) - 1))) / var(--items-per-row-tab));
      max-width: calc((100% - (var(--grid-gap) * (var(--items-per-row-tab) - 1))) / var(--items-per-row-tab));
    }
  }
  @media (max-width: 767px) {
    #section-{{section.id}} .slider-item {
      flex: 0 0 calc((100% - (var(--grid-gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
      max-width: calc((100% - (var(--grid-gap) * (var(--items-per-row-mob) - 1))) / var(--items-per-row-mob));
    }
  }
  {% unless enable_slider %}
  #section-{{section.id}} .slider-list {
    flex-wrap: wrap;
  }
  {% endunless %}
</style>

<div class="section-product-tab-v1{% if border_radius %} border-radius{% endif %}" id="section-{{section.id}}" data-section-id="{{section.id}}"{% if enable_slider %} data-section-type="featured-collection"{% endif %}>
  <div class="{% if template == 'index' or template contains 'page' %}{{ layout_class }}{% endif %} th-vertical-{{ tab_heading_vertical }} controls-position-{{controls_position}}">
    <div class="section-wrapper block-type-{{ style }} {{ items_spacing_row }}{% if style == 'image' %} image-special-style-{{ special_style }}{% endif %}">

      {%- if section_heading != blank -%}
        {%- capture heading_css -%}
          {%- render 'snippet-heading' type: 'render-css' config: heading_style_block.settings, classID: sectionID -%}
        {%- endcapture -%}
        <div class="section-header">{{section_heading}}</div>
      {%- endif -%}

      <div class="section-body">
        <div class="tab-heading-container">
          <ul class="tab-heading tab-heading-{{ tab_title_style }} align-{{ alignment_tab_title }}">
            {%- for block in section.blocks -%}
              {%- if block.type != 'heading-style' -%}
                {%- liquid
                  assign heading = block.settings.heading
                  assign _collection = block.settings.collection
                  assign collection = collections[_collection]
                -%}

                {%- if _collection != blank -%}
                  <li>
                    <a href="{{ collection.url }}"{%- if block.type == 'special-product' -%} class="active"{% endif %}>{%- if heading != blank -%}{{ heading }}{%- else -%}{{ collection.title }}{%- endif -%}</a>
                  </li>
                {%- endif -%}

              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>

        <div class="tab-content">
          {%- for block in section.blocks -%}

            {%- if block.type == 'special-product' -%}
              {%- liquid
                assign style= block.settings.style
                assign _product= block.settings.product
                assign product = all_products[_product]
                assign special_product_position = block.settings.special_product_position
                assign _collection = block.settings.collection
                assign collection = collections[_collection]
              -%}

              <div class="tab-content-inner">
                <div class="tab-items-row">

                  {%- if style == 'normal' -%}
                    {%- render 'product-tabs-v1-normal', collection: collection, limit: limit, enable_slider: enable_slider, gridClass: gridClass, slider_id: slider_id, loop: loop, dots: dots, items_spacing_slider: items_spacing_slider, sectionID: sectionID, controls: controls, autoplay: autoplay, items_resp: items_resp, controls_id: controls_id, autoplay_timeout: autoplay_timeout -%}

                  {%- elsif style == 'special-product' -%}
                    {%- unless _product == blank -%}
                      {%- assign special_product_position = block.settings.special_product_position -%}
                      {%- render 'product-tabs-v1-special-product', product: product, block: block, special_product_position: special_product_position, collection: collection, limit: limit, enable_slider: enable_slider, gridClass: gridClass, slider_id: slider_id, loop: loop, dots: dots, items_spacing_slider: items_spacing_slider, sectionID: sectionID, controls: controls, autoplay: autoplay, items_resp: items_resp, controls_id: controls_id, autoplay_timeout: autoplay_timeout -%}
                    {%- else -%}

                    {%- endunless -%}

                  {%- else -%}
                    {%- liquid
                      assign image = block.settings.image
                      assign link = block.settings.link
                    -%}

                    {%- unless image == blank -%}
                      <div class="block-image">
                        <div class="block-image-inner">
                          <a href="{{ link }}">
                            {%- render 'image-style' image: image, limit: 768 -%}
                          </a>
                        </div>
                      </div>
                    {%- endunless -%}

                    {%- render 'product-tabs-v1-normal', collection: collection, limit: limit, enable_slider: enable_slider, gridClass: gridClass, slider_id: slider_id, loop: loop, dots: dots, items_spacing_slider: items_spacing_slider, sectionID: sectionID, controls: controls, autoplay: autoplay, items_resp: items_resp, controls_id: controls_id, autoplay_timeout: autoplay_timeout -%}

                  {%- endif -%}
                </div>
              </div>
            {%- break -%}
            {%- endif -%}

          {%- endfor -%} 
        </div>

      </div>
    </div>
  </div>
</div>

{%- if enable_slider -%}
<script>
  (function() {
    window.theme = window.theme || {};
    (window.theme.sectionRegister = window.theme.sectionRegister || []).push("featured-collection");
    (window.theme.customElementsList = window.theme.customElementsList || []).push("slider-component");
  })();
</script>
{%- endif -%}

{%- capture section_css -%}
  {{-heading_css-}}
  {%- render 'snippet-theme' type: 'section-style', preClassID: sectionID, classID: bg_class, config: section.settings -%}
{%- endcapture -%}
{%- style -%}{{section_css | strip | strip_newlines | remove: '  ' }}{%- endstyle -%}

{%- schema -%}
{
  "name": "Product Tabs (V1)",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout Mode",
      "default": "boxed",
      "options": [
        { "value": "boxed", "label": "Boxed" },
        { "value": "full", "label": "Wide" }
      ]
    },
    {
      "type": "text",
      "id": "margin",
      "label": "Section Margin",
      "info": "Order: Top Right Bottom Left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "text",
      "id": "padding",
      "label": "Section Padding",
      "info": "Order: Top Right Bottom Left (e.g. 10px 0 10px 0)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "checkbox",
      "id": "border_radius",
      "label": "Enable Border Radius"
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Products per Tab",
      "step": 1,
      "min": 1,
      "max": 20,
      "default": 8
    },
    {
      "type": "header",
      "content": "Grid Settings"
    },
    {
      "type": "text",
      "id": "items_resp",
      "label": "Items Per Row (Responsive)",
      "default": "4,3,2",
      "info": "Format: Desktop-Large, Desktop, Tablet, Mobile"
    },
    {
      "type": "checkbox",
      "id": "items_spacing",
      "label": "Enable Spacing Between Items",
      "default": false
    },
    {
      "type": "header",
      "content": "Tab Heading Styles"
    },
    {
      "type": "select",
      "id": "tab_title_style",
      "label": "Tab Title Border Style",
      "options": [
        { "value": "1", "label": "Style 01" },
        { "value": "2", "label": "Style 02" },
        { "value": "3", "label": "Style 03" }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "alignment_tab_title",
      "label": "Tab Titles Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "tab_heading_vertical",
      "label": "Use Vertical Layout (Sidebar mode)",
      "default": false,
      "info": "Alignment settings above are ignored if this is enabled"
    },
    {
      "type": "header",
      "content": "Slider Settings",
      "info": "Applied to Tabs showing Normal Grids"
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "label": "Enable Native Slider",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Infinite Loop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "Show Arrow Controls",
      "default": true
    },
    {
      "type": "select",
      "id": "controls_position",
      "label": "Controls Position",
      "options": [
        { "value": "1", "label": "Inline with Heading" },
        { "value": "2", "label": "Below Heading" }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "dots",
      "label": "Show Slider Pagination Dots",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_timeout",
      "label": "Autoplay Timeout",
      "step": 0.1,
      "min": 2,
      "max": 10,
      "unit": "s",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "heading-style",
      "limit": 1,
      "name": "Heading Custom Styles",
      "settings": [
        {
          "type": "color",
          "id": "section_heading_color",
          "label": "Text Color"
        },
        {
          "type": "text",
          "id": "section_heading_font_size",
          "label": "Font Size",
          "info": "e.g., 24px"
        },
        {
          "type": "range",
          "id": "section_heading_font_weight",
          "label": "Font Weight",
          "step": 100,
          "min": 100,
          "max": 900,
          "default": 600
        },
        {
          "type": "text",
          "id": "section_heading_line_height",
          "label": "Line Height",
          "info": "e.g., 32px"
        }
      ]
    },
    {
      "type": "special-product",
      "name": "Featured Active Tab",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "Tab Configuration"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Tab Label / Title"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Tab Content (Collection)"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Tab Display Style",
          "default": "normal",
          "options": [
            { "value": "normal", "label": "Normal Grid only" },
            { "value": "special-product", "label": "Grid + Special Product Beside" },
            { "value": "image", "label": "Grid + Image Beside" }
          ]
        },
        {
          "type": "header",
          "content": "Feature Options: Special Product"
        },
        {
          "type": "paragraph",
          "content": "Used if Display Style is set to 'Grid + Special Product Beside'"
        },
        {
          "type": "select",
          "id": "special_product_position",
          "label": "Product Position in Grid",
          "default": "middle",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "left-2", "label": "Left 2" },
            { "value": "middle", "label": "Middle 1" },
            { "value": "middle-2", "label": "Middle 2" },
            { "value": "right", "label": "Right" }
          ]
        },
        {
          "type": "product",
          "id": "product",
          "label": "Select Special Product"
        },
        {
          "type": "textarea",
          "id": "product_text",
          "label": "Special Offer Label Text"
        },
        {
          "type": "header",
          "content": "Feature Options: Image"
        },
        {
          "type": "paragraph",
          "content": "Used if Display Style is set to 'Grid + Image Beside'"
        },
        {
          "type": "range",
          "id": "image_special_style",
          "label": "Image Banner Style",
          "min": 1,
          "max": 3,
          "step": 1,
          "default": 1
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Side Image Upload"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Image Link"
        }
      ]
    },
    {
      "type": "link",
      "name": "Standard Tab",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Tab Label / Title"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Tab Content (Collection)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Tabs (V1)"
    }
  ]
}
{%- endschema -%}